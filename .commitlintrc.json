{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "chain",
        "app",
        "story-generator",
        "publisher",
        "admin-api",
        "admin-ui",
        "devhub",
        "contracts",
        "core-types",
        "shared-utils",
        "core",
        "domain",
        "application",
        "infrastructure",
        "infra",
        "workspace",
        "deps",
        "ci"
      ]
    ],
    "scope-empty": [0],
    "scope-case": [2, "always", "lower-case"]
  }
}
