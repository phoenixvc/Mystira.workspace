# Production Environment Configuration
# Copy this file to .env and fill in the values before running migrations
# BE CAREFUL - This is PRODUCTION!

# Cosmos DB Configuration
COSMOS_ACCOUNT_NAME=mys-prod-core-cosmos-san
COSMOS_RESOURCE_GROUP=mys-prod-core-rg-san
COSMOS_DATABASE_NAME=MystiraAppDb

# Source (for migrations)
SOURCE_COSMOS_ACCOUNT_NAME=prodwusappmystiracosmos
SOURCE_COSMOS_RESOURCE_GROUP=prod-wus-rg-mystira
SOURCE_COSMOS_DATABASE_NAME=MystiraAppDb

# Connection strings (leave empty to auto-detect from Azure)
# Set these if you want to skip Azure CLI lookups
# SOURCE_COSMOS_CONNECTION=
# DEST_COSMOS_CONNECTION=

# Azure Storage Configuration (for blob migrations)
# SOURCE_STORAGE_CONNECTION=
# DEST_STORAGE_CONNECTION=
STORAGE_CONTAINER_NAME=mystira-app-media

# Logging
LOG_LEVEL=Warning
