# =============================================================================
# Mystira Workspace — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for local development.
#
#   cp .env.example .env
#
# The root docker-compose.yml reads these for infrastructure services.
# Individual packages may have their own .env.example for service-specific vars.
# =============================================================================

# ---------------------------------------------------------------------------
# Infrastructure (docker-compose services)
# ---------------------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=mystira
POSTGRES_PASSWORD=mystira_dev
POSTGRES_DB=mystira_dev
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Hardhat (local blockchain node)
HARDHAT_PORT=8545

# ---------------------------------------------------------------------------
# .NET API Services (Admin API + App API)
# ---------------------------------------------------------------------------

# Azure Cosmos DB
COSMOS_DB_CONNECTION_STRING=
COSMOS_DB_NAME=MystiraDb

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
BLOB_CONTAINER_NAME=mystira-media

# JWT Authentication
JWT_ISSUER=mystira-api
JWT_AUDIENCE=mystira-app
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-characters-long

# Azure Communication Services (Email)
ACS_CONNECTION_STRING=
ACS_SENDER_EMAIL=

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Discord Bot (optional — only needed for App API)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=0

# ---------------------------------------------------------------------------
# TypeScript Frontends
# ---------------------------------------------------------------------------

# Publisher (Vite)
VITE_API_BASE_URL=http://localhost:8080/api
VITE_PUBLIC_API_URL=http://localhost:8080/public
VITE_GRPC_ENDPOINT=http://localhost:9090
VITE_ENABLE_MOCK_API=true

# Admin UI (Vite + MSAL)
VITE_AZURE_CLIENT_ID=your-client-id-here
VITE_AZURE_TENANT_ID=your-tenant-id-here
VITE_AZURE_REDIRECT_URI=http://localhost:7001
VITE_AZURE_API_SCOPE=api://your-backend-app-id/access_as_user

# ---------------------------------------------------------------------------
# Python Chain Service
# ---------------------------------------------------------------------------

# Story Protocol RPC
STORY_PROTOCOL_RPC_URL=http://localhost:8545
CHAIN_GRPC_PORT=9090
