{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "local>phoenixvc/Mystira.workspace:renovate-config"
  ],
  "baseBranches": ["dev"],
  "ignorePaths": ["**/node_modules/**", "**/vendor/**", "**/.terraform/**"],
  "packageRules": [
    {
      "description": "Ignore private ACR Docker images (managed via CI/CD)",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "myssharedacr.azurecr.io/admin-api",
        "myssharedacr.azurecr.io/admin-ui",
        "myssharedacr.azurecr.io/chain",
        "myssharedacr.azurecr.io/publisher",
        "myssharedacr.azurecr.io/story-generator"
      ],
      "enabled": false
    }
  ]
}
