{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/install_tools.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(dotnet build*)",
      "Bash(dotnet restore*)",
      "Bash(dotnet test*)"
    ]
  }
}
