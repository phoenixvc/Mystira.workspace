# Mystira Admin UI - Environment Variables Template
# Copy this file to .env.local and fill in your values

# =============================================================================
# API Configuration
# =============================================================================

# Backend API base URL
# Development: http://localhost:5000
# Staging: https://api-staging.mystira.com
# Production: https://api.mystira.com
VITE_API_BASE_URL=http://localhost:5000

# =============================================================================
# Authentication Configuration
# =============================================================================

# Admin UI now authenticates against centralized Mystira.Identity.Api via
# /api/auth/login through the configured Admin API base URL.
# No client-side Azure/MSAL variables are required.


# =============================================================================
# Application Configuration
# =============================================================================

# Environment identifier (development, staging, production)
VITE_ENV=development

# Enable debug logging (true/false)
VITE_DEBUG=true

# =============================================================================
# Optional Configuration
# =============================================================================

# Application version (auto-generated from package.json if not set)
# VITE_APP_VERSION=0.1.0

# Application name
# VITE_APP_NAME=Mystira Admin UI

# =============================================================================
# Notes
# =============================================================================

# - All VITE_ prefixed variables are exposed to the client-side code
# - Never commit .env.local to version control
# - Keep sensitive values in .env.local only
# - Update this template when adding new environment variables
#
# Authentication Setup Requirements:
# 1. Ensure Mystira.Admin.Api is running and can reach Mystira.Identity.Api
# 2. Configure IdentityApi:BaseUrl and JwtSettings in Admin API appsettings
# 3. Use admin credentials accepted by Identity API
