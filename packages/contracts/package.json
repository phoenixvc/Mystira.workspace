{
  "name": "@mystira/contracts",
  "version": "0.6.0-alpha",
  "type": "module",
  "description": "Unified API contracts for Mystira platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app/index.d.ts",
      "import": "./dist/app/index.mjs",
      "require": "./dist/app/index.js"
    },
    "./story-generator": {
      "types": "./dist/story-generator/index.d.ts",
      "import": "./dist/story-generator/index.mjs",
      "require": "./dist/story-generator/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "node scripts/test.mjs"
  },
  "keywords": [
    "mystira",
    "contracts",
    "api",
    "types"
  ],
  "author": "Mystira <jurie@phoenixvc.tech>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/phoenixvc/Mystira.workspace.git",
    "directory": "packages/contracts"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {
    "typescript": ">=4.7.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
