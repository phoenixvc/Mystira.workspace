<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.3" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.4" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Cosmos" Version="10.0.3" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="10.0.3" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.3" />
    <PackageReference Include="WolverineFx" Version="5.16.2" />
    <PackageReference Include="Microsoft.Graph" Version="5.65.0" />
    <PackageReference Include="Azure.Identity" Version="1.18.0" />
    <!-- Remove explicit OpenIdConnect - let Microsoft.Identity.Web handle it -->
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../app/src/Mystira.App.Application/Mystira.App.Application.csproj" />
    <ProjectReference Include="../../../app/src/Mystira.App.Domain/Mystira.App.Domain.csproj" />
    <ProjectReference Include="../../../app/src/Mystira.App.Infrastructure.Azure/Mystira.App.Infrastructure.Azure.csproj" />
    <ProjectReference Include="../../../app/src/Mystira.App.Infrastructure.Data/Mystira.App.Infrastructure.Data.csproj" />
    <ProjectReference Include="../../../shared/Mystira.Shared/Mystira.Shared.csproj" />
  </ItemGroup>

</Project>
