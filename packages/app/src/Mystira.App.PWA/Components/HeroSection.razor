@* Hero Section — two-column layout with portal visual and interactive story demo *@
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<section class="hero-section" aria-label="Mystira hero">
    <!-- Animated background -->
    <div class="hero-bg" aria-hidden="true">
        <div class="hero-bg-gradient"></div>
        <div class="hero-bg-accent-1"></div>
        <div class="hero-bg-accent-2"></div>
        <div class="hero-bg-stars"></div>
        <div class="hero-bg-fade-bottom"></div>
    </div>

    <!-- Particle canvas — scoped to background -->
    <canvas id="particle-canvas" class="hero-particle-canvas" aria-hidden="true"></canvas>

    <div class="hero-container">
        <div class="hero-grid">
            <!-- Left column: copy, CTAs, trust pills, interactive demo -->
            <div class="hero-text-col">
                <HeroBadgePill Text="NEW CHOICE-DRIVEN ADVENTURES" />

                <h1 class="hero-headline">
                    Step Into Worlds Where Your
                    <span class="hero-headline-gradient">Choices Matter</span>
                </h1>

                <p class="hero-subtext">
                    Mystira brings interactive adventures to life. Every decision
                    shapes the story, revealing new paths, new lessons, and new
                    worlds to explore.
                </p>

                <div class="hero-cta-group">
                    @if (ShowCallToActions)
                    {
                        <button type="button" class="hero-btn-primary" @onclick="OnBeginAdventure">
                            Start Adventure
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <line x1="5" y1="12" x2="19" y2="12"/>
                                <polyline points="12 5 19 12 12 19"/>
                            </svg>
                        </button>
                        <a href="/adventures" class="hero-btn-secondary">Explore Worlds</a>
                    }
                </div>

                <HeroTrustPills />

                @if (ShowDescription)
                {
                    <div class="hero-story-demo-wrapper">
                        <InteractiveStoryDemo />
                    </div>
                }
            </div>

            <!-- Right column: portal visual with ornate frame -->
            <div class="hero-visual-col">
                <HeroPortalVisual
                    ShowIntroVideo="@_showIntroVideo"
                    OnIntroComplete="HandleIntroComplete" />

                @if (!_showIntroVideo && _introSeen)
                {
                    <button type="button" class="hero-replay-btn" @onclick="ReplayIntro" title="Replay intro animation">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="1 4 1 10 7 10"/>
                            <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
                        </svg>
                        <span>Replay</span>
                    </button>
                }
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public bool ShowDescription { get; set; } = false;

    [Parameter]
    public bool ShowCallToActions { get; set; } = false;

    [Parameter]
    public EventCallback OnWatchDemoClick { get; set; }

    private bool _particlesInitialized = false;
    private bool _showIntroVideo = false;
    private bool _introSeen = false;

    protected override void OnInitialized()
    {
        // First visit: show intro video; return visits: skip
        // The JS side checks localStorage; we default to showing it
        // and let the portal component handle the transition
        _showIntroVideo = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_particlesInitialized)
        {
            _particlesInitialized = true;
            try
            {
                await JSRuntime.InvokeVoidAsync("MystiraParticles.init", "particle-canvas");

                // Check if intro was already seen
                var seen = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "mystira-hero-intro-seen");
                if (!string.IsNullOrEmpty(seen))
                {
                    _showIntroVideo = false;
                    _introSeen = true;
                    StateHasChanged();
                }
            }
            catch
            {
                // Silently fail if JS interop is not available
            }
        }
    }

    private async Task HandleIntroComplete()
    {
        _showIntroVideo = false;
        _introSeen = true;
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "mystira-hero-intro-seen", "1");
        }
        catch
        {
            // no-op
        }
    }

    private void ReplayIntro()
    {
        _showIntroVideo = true;
    }

    private async Task OnBeginAdventure()
    {
        if (OnWatchDemoClick.HasDelegate)
        {
            await OnWatchDemoClick.InvokeAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("MystiraParticles.destroy");
        }
        catch
        {
            // Silently fail
        }
    }
}
