@* Portal visual — ornate framed M logo with video intro transition *@
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="portal-visual">
    <!-- Ambient glow behind the frame -->
    <div class="portal-ambient-glow" aria-hidden="true"></div>

    <!-- Floating particles around the portal -->
    <div class="portal-particles" aria-hidden="true">
        <span class="portal-particle p1"></span>
        <span class="portal-particle p2"></span>
        <span class="portal-particle p3"></span>
        <span class="portal-particle p4"></span>
        <span class="portal-particle p5"></span>
    </div>

    <!-- Floating container with gentle bob -->
    <div class="portal-float-wrapper">
        <!-- Glass panel behind the frame -->
        <div class="portal-glass-panel" aria-hidden="true"></div>

        <!-- Inner glow -->
        <div class="portal-inner-glow" aria-hidden="true"></div>

        <!-- The framed portal area -->
        <div class="portal-frame-area">
            <!-- Ornate Gold Frame (animated SVG) — IDs are instance-scoped to avoid collisions -->
            <svg class="ornate-frame-svg" viewBox="0 0 400 480" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                <defs>
                    <linearGradient id="@(_idPrefix)-goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="#f6c453" stop-opacity="0.9"/>
                        <stop offset="30%" stop-color="#daa520" stop-opacity="1"/>
                        <stop offset="50%" stop-color="#f6c453" stop-opacity="1"/>
                        <stop offset="70%" stop-color="#b8860b" stop-opacity="0.9"/>
                        <stop offset="100%" stop-color="#f6c453" stop-opacity="0.85"/>
                    </linearGradient>
                    <linearGradient id="@(_idPrefix)-goldHL" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" stop-color="#ffe082" stop-opacity="0.6"/>
                        <stop offset="100%" stop-color="#f6c453" stop-opacity="0.1"/>
                    </linearGradient>
                    <filter id="@(_idPrefix)-fGlow" x="-20%" y="-20%" width="140%" height="140%">
                        <feGaussianBlur stdDeviation="4" result="blur"/>
                        <feColorMatrix in="blur" type="matrix"
                            values="0.4 0 0 0 0.3
                                    0.3 0 0 0 0.15
                                    0 0 0 0 0
                                    0 0 0 0.5 0" result="glow"/>
                        <feMerge>
                            <feMergeNode in="glow"/>
                            <feMergeNode in="SourceGraphic"/>
                        </feMerge>
                    </filter>
                    <filter id="@(_idPrefix)-cGlow" x="-50%" y="-50%" width="200%" height="200%">
                        <feGaussianBlur stdDeviation="6" result="blur"/>
                        <feColorMatrix in="blur" type="matrix"
                            values="0.5 0 0 0 0.4
                                    0.35 0 0 0 0.2
                                    0 0 0 0 0
                                    0 0 0 0.7 0"/>
                    </filter>
                </defs>

                <!-- Outer frame border -->
                <rect x="12" y="12" width="376" height="456" rx="18" ry="18"
                      fill="none" stroke="url(#@(_idPrefix)-goldGrad)" stroke-width="5" filter="url(#@(_idPrefix)-fGlow)"
                      class="frame-outer"/>

                <!-- Inner frame border -->
                <rect x="24" y="24" width="352" height="432" rx="12" ry="12"
                      fill="none" stroke="url(#@(_idPrefix)-goldGrad)" stroke-width="2" opacity="0.6"/>

                <!-- Decorative double line -->
                <rect x="32" y="32" width="336" height="416" rx="8" ry="8"
                      fill="none" stroke="url(#@(_idPrefix)-goldHL)" stroke-width="1" opacity="0.4"/>

                <!-- Corner ornaments — top-left -->
                <g class="corner-ornament corner-tl" filter="url(#@(_idPrefix)-cGlow)">
                    <circle cx="12" cy="12" r="8" fill="url(#@(_idPrefix)-goldGrad)" class="corner-gem"/>
                    <path d="M 12 4 Q 20 12 12 20 Q 4 12 12 4" fill="url(#@(_idPrefix)-goldGrad)" opacity="0.5"/>
                    <circle cx="12" cy="12" r="3" fill="#ffe082" opacity="0.8" class="gem-sparkle"/>
                </g>

                <!-- Corner ornaments — top-right -->
                <g class="corner-ornament corner-tr" filter="url(#@(_idPrefix)-cGlow)">
                    <circle cx="388" cy="12" r="8" fill="url(#@(_idPrefix)-goldGrad)" class="corner-gem"/>
                    <path d="M 388 4 Q 396 12 388 20 Q 380 12 388 4" fill="url(#@(_idPrefix)-goldGrad)" opacity="0.5"/>
                    <circle cx="388" cy="12" r="3" fill="#ffe082" opacity="0.8" class="gem-sparkle"/>
                </g>

                <!-- Corner ornaments — bottom-left -->
                <g class="corner-ornament corner-bl" filter="url(#@(_idPrefix)-cGlow)">
                    <circle cx="12" cy="468" r="8" fill="url(#@(_idPrefix)-goldGrad)" class="corner-gem"/>
                    <path d="M 12 460 Q 20 468 12 476 Q 4 468 12 460" fill="url(#@(_idPrefix)-goldGrad)" opacity="0.5"/>
                    <circle cx="12" cy="468" r="3" fill="#ffe082" opacity="0.8" class="gem-sparkle"/>
                </g>

                <!-- Corner ornaments — bottom-right -->
                <g class="corner-ornament corner-br" filter="url(#@(_idPrefix)-cGlow)">
                    <circle cx="388" cy="468" r="8" fill="url(#@(_idPrefix)-goldGrad)" class="corner-gem"/>
                    <path d="M 388 460 Q 396 468 388 476 Q 380 468 388 460" fill="url(#@(_idPrefix)-goldGrad)" opacity="0.5"/>
                    <circle cx="388" cy="468" r="3" fill="#ffe082" opacity="0.8" class="gem-sparkle"/>
                </g>

                <!-- Top center ornament (diamond) -->
                <g class="top-ornament" filter="url(#@(_idPrefix)-cGlow)">
                    <path d="M 200 2 L 210 12 L 200 22 L 190 12 Z" fill="url(#@(_idPrefix)-goldGrad)" class="top-gem"/>
                    <path d="M 200 5 L 207 12 L 200 19 L 193 12 Z" fill="#ffe082" opacity="0.4"/>
                </g>

                <!-- Bottom center ornament (diamond) -->
                <g class="bottom-ornament" filter="url(#@(_idPrefix)-cGlow)">
                    <path d="M 200 458 L 210 468 L 200 478 L 190 468 Z" fill="url(#@(_idPrefix)-goldGrad)" class="bottom-gem"/>
                    <path d="M 200 461 L 207 468 L 200 475 L 193 468 Z" fill="#ffe082" opacity="0.4"/>
                </g>

                <!-- Side filigree — left -->
                <path d="M 8 120 Q 2 200 8 280" fill="none" stroke="url(#@(_idPrefix)-goldGrad)" stroke-width="1.5" opacity="0.35" class="filigree-left"/>
                <path d="M 8 200 Q 2 240 8 360" fill="none" stroke="url(#@(_idPrefix)-goldGrad)" stroke-width="1" opacity="0.25"/>

                <!-- Side filigree — right -->
                <path d="M 392 120 Q 398 200 392 280" fill="none" stroke="url(#@(_idPrefix)-goldGrad)" stroke-width="1.5" opacity="0.35" class="filigree-right"/>
                <path d="M 392 200 Q 398 240 392 360" fill="none" stroke="url(#@(_idPrefix)-goldGrad)" stroke-width="1" opacity="0.25"/>

                <!-- Animated shimmer line along the frame -->
                <rect x="12" y="12" width="376" height="456" rx="18" ry="18"
                      fill="none" stroke="url(#@(_idPrefix)-goldHL)" stroke-width="2" opacity="0"
                      class="frame-shimmer"/>
            </svg>

            <!-- Inner content area (video or logo) -->
            <div class="portal-inner-content">
                <!-- Cosmic background inside frame -->
                <div class="portal-cosmic-bg" aria-hidden="true"></div>

                <!-- Rotating orbit rings -->
                <div class="orbit-ring orbit-ring-1" aria-hidden="true"></div>
                <div class="orbit-ring orbit-ring-2" aria-hidden="true"></div>

                <!-- Vignette -->
                <div class="portal-vignette" aria-hidden="true"></div>

                @if (_showIntroVideo)
                {
                    <!-- Phase 1: Intro Video -->
                    <div class="portal-video-layer @(_videoFading ? "fading-out" : "")">
                        <video class="portal-video"
                               src="videos/Logo-Twirling-Expansion.mp4"
                               autoplay muted playsinline
                               @ref="_videoElement">
                        </video>
                        <button type="button" class="skip-intro-btn" @onclick="SkipIntro">
                            Skip
                        </button>
                    </div>
                }
                else
                {
                    <!-- Phase 3: Static Logo -->
                    <div class="portal-logo-layer @(_logoEntering ? "entering" : "")">
                        <div class="logo-glow-aura" aria-hidden="true"></div>
                        <img src="images/mystira-logo.webp"
                             alt="Mystira portal artifact"
                             class="portal-logo-img" />
                    </div>
                }
            </div>
        </div>

        <!-- Reflection glow beneath the frame -->
        <div class="portal-reflection" aria-hidden="true"></div>
    </div>
</div>

@code {
    [Parameter]
    public bool ShowIntroVideo { get; set; } = false;

    [Parameter]
    public EventCallback OnIntroComplete { get; set; }

    private ElementReference _videoElement;
    private bool _showIntroVideo;
    private bool _videoFading = false;
    private bool _logoEntering = false;
    private DotNetObjectReference<HeroPortalVisual>? _objRef;

    // Unique prefix for SVG def IDs to avoid collisions if multiple instances render
    private readonly string _idPrefix = $"portal-{Guid.NewGuid().ToString("N")[..8]}";

    protected override void OnInitialized()
    {
        _showIntroVideo = ShowIntroVideo;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _showIntroVideo)
        {
            _objRef = DotNetObjectReference.Create(this);
            try
            {
                await JSRuntime.InvokeVoidAsync("MystiraPortal.bindVideoEnd", _videoElement, _objRef);
            }
            catch
            {
                // Silently fail during prerendering
            }
        }
    }

    [JSInvokable]
    public async Task OnVideoEnded()
    {
        await CompleteIntro();
    }

    private async Task SkipIntro()
    {
        await CompleteIntro();
    }

    private async Task CompleteIntro()
    {
        _videoFading = true;
        StateHasChanged();
        await Task.Delay(400);
        _showIntroVideo = false;
        _logoEntering = true;
        StateHasChanged();
        await Task.Delay(50);
        _logoEntering = false;
        StateHasChanged();

        if (OnIntroComplete.HasDelegate)
        {
            await OnIntroComplete.InvokeAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
    }
}
