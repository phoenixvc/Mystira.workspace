@* Animated badge pill for the hero section *@

<div class="hero-badge-pill" aria-hidden="true">
    <svg class="badge-sparkle-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 2L14.09 8.26L20 9.27L15.55 13.97L16.91 20L12 16.9L7.09 20L8.45 13.97L4 9.27L9.91 8.26L12 2Z"
              fill="currentColor" opacity="0.9"/>
    </svg>
    <span>@Text</span>
</div>

@code {
    [Parameter]
    public string Text { get; set; } = "NEW CHOICE-DRIVEN ADVENTURES";
}
