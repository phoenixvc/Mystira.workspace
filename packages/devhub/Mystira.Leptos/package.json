{
  "name": "mystira-leptos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "css": "npx tailwindcss -i ./styles/input.css -o ./styles/output.css",
    "css:watch": "npx tailwindcss -i ./styles/input.css -o ./styles/output.css --watch",
    "dev": "trunk serve",
    "build": "command -v trunk >/dev/null 2>&1 && trunk build --release || echo 'Skipping leptos build: trunk CLI not installed'",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "tailwindcss": "^4.2.1"
  }
}
