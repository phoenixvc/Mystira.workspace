{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**", "artifacts/**", "cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [],
      "outputs": [],
      "inputs": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "vitest.config.*",
        "src/test/setup.*"
      ]
    },
    "test:coverage": {
      "dependsOn": [],
      "outputs": ["coverage/**"],
      "passThroughEnv": ["NODE_ENV"]
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
