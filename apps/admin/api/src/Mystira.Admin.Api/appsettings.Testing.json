{
  "// ⚠️ TESTING CONFIGURATION": "Configuration for integration tests",
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CosmosDb": "",
    "AzureStorage": "UseDevelopmentStorage=true"
  },
  "Azure": {
    "BlobStorage": {
      "ContainerName": "test-container",
      "MaxFileSizeMB": 10
    },
    "CosmosDb": {
      "DatabaseName": "TestDb"
    }
  }
}
