@* Modal for assigning a player (Profile, Guest, or AI) to a character *@
@using Mystira.App.PWA.Models
@using Mystira.App.PWA.Components.Assignment

@if (ShowModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="playerAssignmentModalTitle">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="playerAssignmentModalTitle">Assign Player to @CharacterName</h5>
                    <button type="button" class="btn-close" aria-label="Close modal" @onclick="HandleClose"></button>
                </div>
                <div class="modal-body">
                    <!-- Validation Message -->
                    @if (!string.IsNullOrEmpty(ValidationMessage))
                    {
                        <div class="alert alert-warning mb-3" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            @ValidationMessage
                        </div>
                    }

                    <!-- Tab Navigation -->
                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(CurrentTab == "profiles" ? "active" : "")"
                                role="tab" aria-selected="@(CurrentTab == "profiles" ? "true" : "false")"
                                id="tab-profiles" aria-controls="tabpanel-profiles"
                                @onclick="@(() => SetTab("profiles"))">
                                <i class="fas fa-users me-1"></i>Profiles
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(CurrentTab == "new-profile" ? "active" : "")"
                                role="tab" aria-selected="@(CurrentTab == "new-profile" ? "true" : "false")"
                                id="tab-new-profile" aria-controls="tabpanel-new-profile"
                                @onclick="@(() => SetTab("new-profile"))">
                                <i class="fas fa-user-plus me-1"></i>New Profile
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(CurrentTab == "guest" ? "active" : "")"
                                role="tab" aria-selected="@(CurrentTab == "guest" ? "true" : "false")"
                                id="tab-guest" aria-controls="tabpanel-guest"
                                @onclick="@(() => SetTab("guest"))">
                                <i class="fas fa-user-circle me-1"></i>Guest
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(CurrentTab == "ai" ? "active" : "")"
                                role="tab" aria-selected="@(CurrentTab == "ai" ? "true" : "false")"
                                id="tab-ai" aria-controls="tabpanel-ai"
                                @onclick="@(() => SetTab("ai"))">
                                <i class="fas fa-robot me-1"></i>AI
                            </button>
                        </li>
                    </ul>

                    @if (CurrentTab == "profiles")
                    {
                        <div role="tabpanel" id="tabpanel-profiles" aria-labelledby="tab-profiles">
                            <ProfileSelectionTab
                                AvailableProfiles="@AvailableProfiles"
                                SelectedProfileId="@SelectedProfileId"
                                SelectedProfileIdChanged="@((id) => SelectedProfileId = id)" />
                        </div>
                    }
                    else if (CurrentTab == "new-profile")
                    {
                        <div role="tabpanel" id="tabpanel-new-profile" aria-labelledby="tab-new-profile">
                            <NewProfileTab
                                ProfileName="@NewProfileName"
                                ProfileNameChanged="@((name) => NewProfileName = name)"
                                AgeRange="@NewProfileAgeRange"
                                AgeRangeChanged="@((age) => NewProfileAgeRange = age)"
                                SelectedAvatarMediaId="@SelectedAvatarMediaId"
                                SelectedAvatarMediaIdChanged="@((id) => SelectedAvatarMediaId = id)"
                                IsAvatarSelected="@IsAvatarSelected"
                                IsAvatarSelectedChanged="@((selected) => IsAvatarSelected = selected)" />
                        </div>
                    }
                    else if (CurrentTab == "guest")
                    {
                        <div role="tabpanel" id="tabpanel-guest" aria-labelledby="tab-guest">
                            <GuestPlayerTab
                                GuestName="@GuestName"
                                GuestNameChanged="@((name) => GuestName = name)"
                                GuestAgeRange="@GuestAgeRange"
                                GuestAgeRangeChanged="@((age) => GuestAgeRange = age)" />
                        </div>
                    }
                    else if (CurrentTab == "ai")
                    {
                        <div role="tabpanel" id="tabpanel-ai" aria-labelledby="tab-ai">
                            <AiPlayerTab />
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HandleClose">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="HandleConfirm"
                        disabled="@(!CanConfirm)">
                        Assign Player
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool ShowModal { get; set; }

    [Parameter]
    public string? CharacterName { get; set; }

    [Parameter]
    public List<UserProfile> AvailableProfiles { get; set; } = new();

    [Parameter]
    public string? ValidationMessage { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<PlayerAssignmentResult> OnConfirm { get; set; }

    // Form state
    private string CurrentTab { get; set; } = "profiles";
    private string SelectedProfileId { get; set; } = string.Empty;
    private string GuestName { get; set; } = string.Empty;
    private string GuestAgeRange { get; set; } = string.Empty;
    private string NewProfileName { get; set; } = string.Empty;
    private string NewProfileAgeRange { get; set; } = string.Empty;
    private string? SelectedAvatarMediaId { get; set; }
    private bool IsAvatarSelected { get; set; }

    private bool CanConfirm => CurrentTab switch
    {
        "profiles" => !string.IsNullOrEmpty(SelectedProfileId),
        "new-profile" => !string.IsNullOrEmpty(NewProfileName) && !string.IsNullOrEmpty(NewProfileAgeRange),
        "guest" => !string.IsNullOrEmpty(GuestName) && !string.IsNullOrEmpty(GuestAgeRange),
        "ai" => true,
        _ => false
    };

    private bool _previousShowModal;

    protected override void OnParametersSet()
    {
        if (ShowModal && !_previousShowModal)
        {
            ResetForm();
        }
        _previousShowModal = ShowModal;
    }

    private void ResetForm()
    {
        CurrentTab = "profiles";
        SelectedProfileId = string.Empty;
        GuestName = string.Empty;
        GuestAgeRange = string.Empty;
        NewProfileName = string.Empty;
        NewProfileAgeRange = string.Empty;
        SelectedAvatarMediaId = null;
        IsAvatarSelected = false;
    }

    private void SetTab(string tab) => CurrentTab = tab;

    private async Task HandleClose() => await OnClose.InvokeAsync();

    private async Task HandleConfirm()
    {
        var result = new PlayerAssignmentResult
        {
            Tab = CurrentTab,
            SelectedProfileId = SelectedProfileId,
            SelectedProfile = AvailableProfiles.FirstOrDefault(p => p.Id == SelectedProfileId),
            GuestName = GuestName,
            GuestAgeRange = GuestAgeRange,
            NewProfileName = NewProfileName,
            NewProfileAgeRange = NewProfileAgeRange,
            SelectedAvatarMediaId = SelectedAvatarMediaId
        };

        await OnConfirm.InvokeAsync(result);
    }

    /// <summary>
    /// Result object containing the player assignment data selected in the modal.
    /// </summary>
    public class PlayerAssignmentResult
    {
        public string Tab { get; set; } = string.Empty;
        public string SelectedProfileId { get; set; } = string.Empty;
        public UserProfile? SelectedProfile { get; set; }
        public string GuestName { get; set; } = string.Empty;
        public string GuestAgeRange { get; set; } = string.Empty;
        public string NewProfileName { get; set; } = string.Empty;
        public string NewProfileAgeRange { get; set; } = string.Empty;
        public string? SelectedAvatarMediaId { get; set; }
    }
}
