@* Tab content for selecting an existing profile *@
@using Mystira.App.PWA.Models

<div class="alert alert-info mb-3">
    <i class="fas fa-info-circle me-2"></i>
    <small>Note: A single profile can be used for multiple character assignments.</small>
</div>
<div class="mb-3">
    <label class="form-label">Select Profile</label>
    <select class="form-select" value="@SelectedProfileId" @onchange="OnProfileSelected">
        <option value="">Choose a profile...</option>
        @foreach (var profile in AvailableProfiles)
        {
            <option @key="profile.Id" value="@profile.Id">@profile.Name (@profile.DisplayAgeRange)</option>
        }
    </select>
</div>

@code {
    [Parameter]
    public List<UserProfile> AvailableProfiles { get; set; } = new();

    [Parameter]
    public string SelectedProfileId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> SelectedProfileIdChanged { get; set; }

    private async Task OnProfileSelected(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        await SelectedProfileIdChanged.InvokeAsync(value);
    }
}
