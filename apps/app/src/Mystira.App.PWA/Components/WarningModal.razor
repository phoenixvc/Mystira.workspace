@if (ShowModal)
{
    <div class="modal-backdrop fade show" style="display: block;"></div>
    <div class="modal fade show" style="display: block;" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="@_titleId">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title" id="@_titleId">
                        <i class="fas fa-@Icon @IconColor me-2"></i>
                        @Title
                    </h5>
                    <button type="button" class="btn-close" @onclick="OnCancel" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @BodyContent
                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" id="@_checkboxId"
                               checked="@(_dontShowAgain ? true : (bool?)null)"
                               @onchange="OnCheckboxChanged" />
                        <label class="form-check-label" for="@_checkboxId">
                            Don't show this message again
                        </label>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" @onclick="OnCancel">
                        <i class="fas fa-arrow-left me-2"></i>@CancelText
                    </button>
                    <button type="button" class="btn btn-primary-custom" @onclick="HandleContinue">
                        <i class="fas fa-play me-2"></i>@ContinueText
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly string _titleId = $"wm_title_{Guid.NewGuid():N}";
    private readonly string _checkboxId = $"wm_{Guid.NewGuid():N}";
    private bool _dontShowAgain;

    [Parameter] public bool ShowModal { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = "exclamation-circle";
    [Parameter] public string IconColor { get; set; } = "text-warning";
    [Parameter] public RenderFragment? BodyContent { get; set; }
    [Parameter] public string CancelText { get; set; } = "Go Back";
    [Parameter] public string ContinueText { get; set; } = "Continue";
    [Parameter] public bool DontShowAgain { get; set; }
    [Parameter] public EventCallback<bool> DontShowAgainChanged { get; set; }
    [Parameter] public EventCallback OnContinue { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    protected override void OnParametersSet()
    {
        _dontShowAgain = DontShowAgain;
    }

    private async Task OnCheckboxChanged(ChangeEventArgs e)
    {
        _dontShowAgain = (bool)(e.Value ?? false);
        if (DontShowAgainChanged.HasDelegate)
        {
            await DontShowAgainChanged.InvokeAsync(_dontShowAgain);
        }
    }

    private async Task HandleContinue()
    {
        if (DontShowAgainChanged.HasDelegate)
        {
            await DontShowAgainChanged.InvokeAsync(_dontShowAgain);
        }
        if (OnContinue.HasDelegate)
        {
            await OnContinue.InvokeAsync();
        }
    }
}
