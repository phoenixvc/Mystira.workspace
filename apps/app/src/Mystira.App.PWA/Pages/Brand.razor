@page "/brand"
@layout BrandLayout

<PageTitle>Mystira Brand</PageTitle>

<div class="brand-page">

  <header class="brand-hero">
    <div class="hero-top">
      <div>
        <h1>Mystira</h1>
        <p class="hero-tagline">Magical choice-based storytelling for ages 3–12.</p>
      </div>

      <ThemeToggle />
    </div>

    <p class="hero-blurb">
      A narrative-driven gaming platform with branching stories, moral compass growth,
      age-appropriate achievements, and character identity.
    </p>
  </header>

  <section class="brand-section">
    <h2>Typography</h2>
    <TypographyShowcase />
  </section>

  <section class="brand-section">
    <h2>Buttons</h2>
    <ButtonShowcase />
  </section>

  <section class="brand-section">
    <h2>Status</h2>
    <StatusDemo />
  </section>

  <section class="brand-section">
    <h2>Motion</h2>
    <MotionDemo />
  </section>

</div>
