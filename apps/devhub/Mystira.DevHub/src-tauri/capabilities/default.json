{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "opener:allow-open-url",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": ["$DOWNLOAD/**", "$DOCUMENT/**", "$HOME/**"]
    }
  ]
}
