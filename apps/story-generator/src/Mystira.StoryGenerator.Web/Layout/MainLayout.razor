@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="auth-section">
                @if (isAuthenticated)
                {
                    <button class="btn btn-outline-danger btn-sm" @onclick="LogoutAsync">Logout</button>
                }
                else
                {
                    <a href="/login" class="btn btn-primary btn-sm">Login</a>
                }
            </div>
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@implements IDisposable

@code {
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        await CheckAuthStatus();
        AuthService.AuthenticationStateChanged += OnAuthenticationStateChanged;
    }

    private async void OnAuthenticationStateChanged(object? sender, bool isAuth)
    {
        try
        {
            isAuthenticated = isAuth;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            // Log error but don't crash the component
            Console.WriteLine($"Error in authentication state change: {ex.Message}");
        }
    }

    private async Task CheckAuthStatus()
    {
        try
        {
            isAuthenticated = await AuthService.IsAuthenticatedAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error checking auth status: {ex.Message}");
            isAuthenticated = false;
        }
    }

    private async Task LogoutAsync()
    {
        try
        {
            await AuthService.LogoutAsync();
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            // Log error and show user-friendly message
            Console.WriteLine($"Error during logout: {ex.Message}");
            // Could show a toast/notification here
        }
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= OnAuthenticationStateChanged;
    }
}

<style>
    .auth-section {
        margin-right: 1rem;
    }

    .btn {
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
        text-decoration: none;
        border-radius: 0.25rem;
        cursor: pointer;
    }

    .btn-primary {
        background: #007bff;
        color: white;
        border: 1px solid #007bff;
    }

    .btn-primary:hover {
        background: #0056b3;
        border-color: #0056b3;
    }

    .btn-outline-danger {
        background: transparent;
        color: #dc3545;
        border: 1px solid #dc3545;
    }

    .btn-outline-danger:hover {
        background: #dc3545;
        color: white;
    }
</style>
