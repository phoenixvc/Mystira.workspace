@* Active adventure session card for displaying in-progress game sessions *@

<div class="col-md-6 col-lg-4 mb-3">
    <div class="active-adventure-card h-100">
        <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <h6 class="card-title mb-0">@ScenarioTitle</h6>
                <span class="active-adventure-status">
                    <i class="fas fa-circle"></i>@StatusText
                </span>
            </div>
            <p class="active-adventure-meta">
                <i class="fas fa-calendar-alt"></i>
                Started: @StartedAt.ToLocalTime().ToString("dd-MMM-yy HH:mm")
            </p>
            <div class="mt-auto">
                <button class="btn-continue-adventure"
                        @onclick="HandleContinueClick"
                        disabled="@(IsDisabled ? true : null)">
                    <i class="fas fa-play"></i>
                    Continue
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public string ScenarioTitle { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public DateTime StartedAt { get; set; }

    [Parameter]
    public string StatusText { get; set; } = "In Progress";

    [Parameter]
    public bool IsDisabled { get; set; }

    [Parameter]
    public EventCallback OnContinue { get; set; }

    private async Task HandleContinueClick()
    {
        await OnContinue.InvokeAsync();
    }
}
