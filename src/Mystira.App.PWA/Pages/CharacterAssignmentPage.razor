@page "/character-assignment/{scenarioId}"
@inject NavigationManager NavigationManager
@inject ICharacterAssignmentService CharacterAssignmentService
@inject IAuthService AuthService
@inject IGameSessionService GameSessionService
@inject IApiClient ApiClient
@inject ILogger<CharacterAssignment> Logger
@inject IJSRuntime JSRuntime
@inject ISettingsService SettingsService
@inject Mystira.App.PWA.Services.Music.IAudioCacheService AudioCacheService
@inject Mystira.App.PWA.Services.Music.SceneAudioOrchestrator AudioOrchestrator
@using System.Linq
@implements IAsyncDisposable

<PageTitle>Assign Players • Mystira</PageTitle>

@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center loading-container">
        <div class="text-center">
            <div class="spinner-border text-primary-custom mb-3" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted">Preparing character assignment...</p>
        </div>
    </div>
}
else if (assignmentData?.Scenario == null)
{
    <div class="d-flex justify-content-center align-items-center loading-container">
        <div class="text-center">
            <i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
            <h3>Scenario Not Found</h3>
            <p class="text-muted mb-4">We couldn't load the scenario for character assignment.</p>
            <button class="btn btn-primary-custom" @onclick="GoBack">
                <i class="fas fa-arrow-left me-2"></i>Back to Adventures
            </button>
        </div>
    </div>
}
else
{
    <div class="container-fluid py-4">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex align-items-center mb-3">
                    <div>
                        <h2 class="mb-1">Assign Players</h2>
                        <p class="text-muted mb-0">@assignmentData.Scenario.Title</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Character Cards Grid -->
        <div class="row g-4 mb-4">
            @for (int i = 0; i < characterAssignments.Count; i++)
            {
                var assignment = characterAssignments[i];
                var cardIndex = i;

                <CharacterCard
                    Assignment="@assignment"
                    CardIndex="@cardIndex"
                    IsPlayingAudio="@(isPlayingAudio == assignment.Audio)"
                    GetMediaUrl="@((id) => ApiClient.GetMediaResourceEndpointUrl(id))"
                    OnImagePreview="@PreviewImage"
                    OnAudioPlay="@PlayAudio"
                    OnAssignPlayer="@(async (idx) => await OpenPlayerAssignment(idx))"
                    OnRemovePlayer="@RemovePlayerAssignment" />
            }
        </div>

        <!-- Action Buttons -->
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <button class="btn btn-outline-secondary" @onclick="GoBack">
                        <i class="fas fa-arrow-left me-2"></i>Back
                    </button>

                    <div class="d-flex gap-2 flex-wrap">
                        @if (HasUnassignedCharacters)
                        {
                            <button class="btn btn-outline-info" @onclick="FillRemainingWithGuests"
                                title="Assign Guests players to all remaining unassigned characters">
                                <i class="fas fa-robot me-2"></i>Fill with Guests
                            </button>
                        }

                        <button class="btn btn-outline-primary" @onclick="ManageProfiles">
                            <i class="fas fa-users me-2"></i>Manage Profiles
                        </button>

                        <div class="btn-disabled-wrapper">
                            <button class="btn btn-primary-custom btn-lg" @onclick="BeginSession"
                                disabled="@(!CanBeginSession || isStartingSession)">
                                @if (isStartingSession)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    <span>Starting...</span>
                                }
                                else
                                {
                                    <i class="fas fa-play me-2"></i>
                                    <span>Begin Session</span>
                                }
                            </button>
                            @if (!CanBeginSession && !isStartingSession)
                            {
                                <span class="disabled-tooltip">
                                    <i class="fas fa-info-circle me-1"></i>Assign all characters first
                                </span>
                            }
                        </div>
                    </div>
                </div>

                @if (!CanBeginSession)
                {
                    <div class="alert alert-warning mt-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <div>
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            @UnassignedCount character@(UnassignedCount != 1 ? "s" : "") still need@(UnassignedCount == 1 ? "s" : "") a player assignment.
                        </div>
                        <button class="btn btn-sm btn-outline-warning" @onclick="FillRemainingWithGuests">
                            <i class="fas fa-robot me-2"></i>Assign Guests to remaining
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Player Assignment Modal -->
<PlayerAssignmentModal
    ShowModal="@showPlayerAssignmentModal"
    CharacterName="@currentAssignment?.CharacterName"
    AvailableProfiles="@availableProfiles"
    ValidationMessage="@validationMessage"
    OnClose="@ClosePlayerAssignment"
    OnConfirm="@HandlePlayerAssignmentResult" />

<!-- Image Preview Modal -->
@if (showImagePreview)
{
    <div class="modal fade show d-block modal-backdrop-dark">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content bg-transparent border-0">
                <div class="modal-body p-0 text-center">
                    <img src="@previewImage" class="img-fluid" alt="Character Preview" />
                    <button type="button" class="btn btn-light btn-lg position-absolute top-0 end-0 m-3"
                        @onclick="CloseImagePreview">
                        &#10060;
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Guest Warning Modal -->
<GuestWarningModal
    ShowModal="showGuestWarningModal"
    @bind-DoNotShowAgain="dontShowGuestWarning"
    OnContinue="ContinueWithGuestAssignments"
    OnCancel="CancelGuestWarning">
</GuestWarningModal>

<!-- Age Group Mismatch Modal -->
<AgeGroupMismatchModal
    ShowModal="showAgeGroupWarningModal"
    AgeGroupDisplayName="@AgeRanges.GetDisplayName(assignmentData?.Scenario?.AgeGroup ?? string.Empty)"
    MismatchedProfiles="@mismatchedProfileNames"
    DontShowAgain="@ageGroupDontShowAgain"
    DontShowAgainChanged="@((bool val) => ageGroupDontShowAgain = val)"
    OnContinue="ContinueAfterAgeGroupWarning"
    OnCancel="CancelAgeGroupWarning">
</AgeGroupMismatchModal>

<!-- Replay Warning Modal -->
<ReplayWarningModal
    ShowModal="showReplayWarningModal"
    ReplayingProfiles="@replayingProfileNames"
    DontShowAgain="@replayDontShowAgain"
    DontShowAgainChanged="@((bool val) => replayDontShowAgain = val)"
    OnContinue="ContinueAfterReplayWarning"
    OnCancel="CancelReplayWarning">
</ReplayWarningModal>

<!-- Initial Assignment Prompt Modal (shown on load for toddler scenarios only) -->
@if (showInitialAssignmentPrompt)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-user-friends me-2"></i>
                        Who is playing?
                    </h5>
                </div>
                <div class="modal-body">
                    <p class="text-muted">
                        Choose a player once and we will assign them to all active characters for this adventure.
                    </p>

                    <!-- Tabs Navigation -->
                    <ul class="nav nav-tabs mb-3">
                        <li class="nav-item">
                            <button class="@GetTabClass("profiles")" @onclick="SetTabProfiles">
                                <i class="fas fa-id-badge me-1"></i> Profiles
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="@GetTabClass("new-profile")" @onclick="SetTabNewProfile">
                                <i class="fas fa-user-plus me-1"></i> New Profile
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="@GetTabClass("guest")" @onclick="SetTabGuest">
                                <i class="fas fa-user-clock me-1"></i> Guest
                            </button>
                        </li>
                    </ul>

                    <!-- Tab Contents -->
                    <div>
                        @if (assignmentTab == "profiles")
                        {
                            <div class="mb-3">
                                @if (!availableProfiles.Any())
                                {
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle me-2"></i>
                                        No profiles yet. Create a new one or continue as a guest.
                                    </div>
                                }
                                else
                                {
                                    <div class="list-group">
                                        @foreach (var profile in availableProfiles.OrderBy(p => p.Name))
                                        {
                                            <label class="list-group-item d-flex align-items-center" for="ip_@profile.Id">
                                                <input type="radio"
                                                       id="ip_@profile.Id"
                                                       name="initialProfile"
                                                       class="form-check-input me-3"
                                                       value="@profile.Id"
                                                       @onchange="(e => selectedProfileId = e.Value?.ToString() ?? string.Empty)"
                                                       checked="@(selectedProfileId == profile.Id)" />
                                                <div class="flex-grow-1">
                                                    <div class="fw-semibold">@profile.Name</div>
                                                    <small class="text-muted">Age: @profile.DisplayAgeRange</small>
                                                </div>
                                            </label>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else if (assignmentTab == "new-profile")
                        {
                            <div class="mb-3">
                                <label class="form-label">Name *</label>
                                <input type="text" class="form-control" @bind="newProfileName" placeholder="Enter name" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Age Range *</label>
                                <select class="form-select" @bind="newProfileAgeRange">
                                    <option value="">Select age range</option>
                                    @foreach (var range in AgeRanges.All)
                                    {
                                        <option value="@range">@AgeRanges.GetDisplayName(range)</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Choose an avatar (optional)</label>
                                @if (string.IsNullOrEmpty(newProfileAgeRange))
                                {
                                    <div class="alert alert-secondary">Select an age range to see avatar options.</div>
                                }
                                else
                                {
                                    <AvatarCarousel AgeGroup="@newProfileAgeRange" OnAvatarSelected="OnAvatarSelected" />
                                }
                            </div>
                        }
                        else if (assignmentTab == "guest")
                        {
                            <div class="mb-3">
                                <label class="form-label">Display Name *</label>
                                <input type="text" class="form-control" @bind="guestName" placeholder="Enter guest name" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Age Range</label>
                                <select class="form-select" @bind="guestAgeRange">
                                    <option value="">Prefer not to say</option>
                                    @foreach (var range in AgeRanges.All)
                                    {
                                        <option value="@range">@AgeRanges.GetDisplayName(range)</option>
                                    }
                                </select>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(validationMessage))
                    {
                        <div class="alert alert-danger mt-3">@validationMessage</div>
                    }
                </div>
                <div class="modal-footer">
                    @* Cancel is specifically requested for toddler (1-2) assignment flow *@
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelToddlerAssignment" disabled="@isStartingSession">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmInitialAssignment" disabled="@(!CanConfirmInitialAssignment() || isStartingSession)">
                        @if (isStartingSession)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Starting...</span>
                        }
                        else
                        {
                            <span>Assign to All</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string ScenarioId { get; set; } = string.Empty;

    private CharacterAssignmentResponse? assignmentData;
    private List<CharacterAssignment> characterAssignments = new();
    private List<UserProfile> availableProfiles = new();
    private bool isLoading = true;
    private bool isStartingSession = false;

    // Modal state
    private bool showPlayerAssignmentModal = false;
    private bool showImagePreview = false;
    private bool showGuestWarningModal = false;
    private bool showAgeGroupWarningModal = false;
    private bool showInitialAssignmentPrompt = false;
    private string assignmentTab = "profiles";
    private CharacterAssignment? currentAssignment;
    private int currentAssignmentIndex = -1;

    // Form state
    private string selectedProfileId = string.Empty;
    private string guestName = string.Empty;
    private string guestAgeRange = string.Empty;
    private string newProfileName = string.Empty;
    private string newProfileAgeRange = string.Empty;
    private string? selectedAvatarMediaId;
    private string? previewImage;
    private string validationMessage = string.Empty;
    private bool ageGroupDontShowAgain = false;
    private bool dontShowGuestWarning = false;
    private List<string> mismatchedProfileNames = new();
    private bool showReplayWarningModal = false;
    private bool replayDontShowAgain = false;
    private List<string> replayingProfileNames = new();

    // Mode helpers
    private bool IsToddlerScenario => assignmentData?.Scenario?.AgeGroup == "1-2";

    // Audio
    private string? isPlayingAudio = null;

    public async ValueTask DisposeAsync()
    {
        try
        {
            // If we are starting a session, we want the music to continue to the game page.
            // Otherwise (e.g. going back to home), we stop all audio.
            if (!isStartingSession)
            {
                await AudioOrchestrator.StopAllAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error disposing audio in CharacterAssignment");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Logger.LogInformation("Initializing character assignment for scenario: {ScenarioId}", ScenarioId);
            await LoadCharacterAssignmentData();

            // Load settings
            dontShowGuestWarning = !await SettingsService.GetShowGuestWarningAsync();

            // Show the initial bulk assignment prompt only for toddler scenarios (age group 1-2)
            showInitialAssignmentPrompt = IsToddlerScenario;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing character assignment");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadCharacterAssignmentData()
    {
        assignmentData = await CharacterAssignmentService.GetCharacterAssignmentDataAsync(ScenarioId, characterAssignments);

        if (assignmentData != null)
        {
            characterAssignments = assignmentData.CharacterAssignments;
            availableProfiles = assignmentData.AvailableProfiles;

            if (assignmentData.Scenario != null)
            {
                // Pre-cache all audio for this scenario
                _ = AudioCacheService.CacheScenarioAudioAsync(assignmentData.Scenario);
            }
        }
    }

    private async Task CancelToddlerAssignment()
    {
        try
        {
            // Stop any playing audio preview
            if (!string.IsNullOrEmpty(isPlayingAudio))
            {
                try
                {
                    await AudioOrchestrator.StopAllAsync();
                    isPlayingAudio = null;
                }
                catch { /* best-effort */ }
            }

            // Close the initial prompt and navigate back to the previous hub/home
            showInitialAssignmentPrompt = false;
            StateHasChanged();
            GoBack();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during CancelToddlerAssignment");
            // Fallback navigation to ensure user isn't stuck
            GoBack();
        }
    }

    private bool CanConfirmInitialAssignment()
    {
        if (assignmentTab == "profiles")
        {
            return !string.IsNullOrWhiteSpace(selectedProfileId);
        }
        if (assignmentTab == "new-profile")
        {
            return !string.IsNullOrWhiteSpace(newProfileName) && !string.IsNullOrWhiteSpace(newProfileAgeRange);
        }
        if (assignmentTab == "guest")
        {
            return !string.IsNullOrWhiteSpace(guestName);
        }
        return false;
    }

    private async Task ConfirmInitialAssignment()
    {
        validationMessage = string.Empty;

        if (assignmentTab == "profiles")
        {
            var profile = availableProfiles.FirstOrDefault(p => p.Id == selectedProfileId);
            if (profile == null)
            {
                validationMessage = "Please select a profile.";
                StateHasChanged();
                return;
            }

            foreach (var ca in characterAssignments)
            {
                if (ca.IsUnused) continue;
                ca.PlayerAssignment = new PlayerAssignment
                {
                    Type = "Profile",
                    ProfileId = profile.Id,
                    ProfileName = profile.Name,
                    SelectedAvatarMediaId = profile.SelectedAvatarMediaId
                };
            }

            // For 1-2 age group, start immediately after a single selection
            if (IsToddlerScenario)
            {
                isStartingSession = true;
                StateHasChanged();
                Logger.LogInformation("Toddler scenario: Auto-starting with selected profile {ProfileId}", HashForLog(profile.Id));
                await CheckForWarningsAndContinue(true);
                showInitialAssignmentPrompt = false;
                return;
            }

            showInitialAssignmentPrompt = false;
            StateHasChanged();
            return;
        }

        if (assignmentTab == "new-profile")
        {
            var account = await AuthService.GetCurrentAccountAsync();
            if (account == null)
            {
                validationMessage = "Unable to create profile. Please try again.";
                StateHasChanged();
                return;
            }

            isStartingSession = true;
            StateHasChanged();

            var profileRequest = new CreateUserProfileRequest
            {
                Name = newProfileName,
                AgeGroup = newProfileAgeRange,
                AccountId = account.Id,
                IsGuest = false,
                AvatarMediaId = selectedAvatarMediaId,
                SelectedAvatarMediaId = selectedAvatarMediaId
            };

            var createdProfile = await ApiClient.CreateProfileAsync(profileRequest);
            if (createdProfile == null)
            {
                isStartingSession = false;
                validationMessage = "Failed to create profile. Please try again.";
                StateHasChanged();
                return;
            }

            // Add to available profiles for later use
            availableProfiles.Add(createdProfile);

            foreach (var ca in characterAssignments)
            {
                if (ca.IsUnused) continue;
                ca.PlayerAssignment = new PlayerAssignment
                {
                    Type = "Profile",
                    ProfileId = createdProfile.Id,
                    ProfileName = createdProfile.Name,
                    SelectedAvatarMediaId = createdProfile.SelectedAvatarMediaId
                };
            }

            if (IsToddlerScenario)
            {
                Logger.LogInformation("Toddler scenario: Auto-starting with new profile {ProfileId}", HashForLog(createdProfile.Id));
                await CheckForWarningsAndContinue(true);
                showInitialAssignmentPrompt = false;
                return;
            }

            showInitialAssignmentPrompt = false;
            // Reset new profile form state
            newProfileName = string.Empty;
            newProfileAgeRange = string.Empty;
            selectedAvatarMediaId = null;

            StateHasChanged();
            return;
        }

        if (assignmentTab == "guest")
        {
            isStartingSession = true;
            StateHasChanged();

            // Defer to guest warning modal before applying unless user opted out
            if (dontShowGuestWarning)
            {
                pendingInitialGuestApplyAll = true;
                await ContinueWithGuestAssignments();
                return;
            }
            else
            {
                isStartingSession = false; // Reset while showing modal
                pendingInitialGuestApplyAll = true;
                showGuestWarningModal = true;
                showInitialAssignmentPrompt = false; // Hide the prompt so warning is visible
                StateHasChanged();
                return;
            }
        }
    }

    private bool pendingInitialGuestApplyAll = false;

    private string GetTabClass(string tabName) =>
        $"nav-link {(assignmentTab == tabName ? "active" : string.Empty)}";

    private void SetTabProfiles()
    {
        assignmentTab = "profiles";
    }

    private void SetTabNewProfile()
    {
        assignmentTab = "new-profile";
    }

    private void SetTabGuest()
    {
        assignmentTab = "guest";
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/home");
    }

    private async Task OpenPlayerAssignment(int index)
    {
        try
        {
            // In toddler scenarios, do not allow per-character assignments
            if (IsToddlerScenario)
            {
                return;
            }
            currentAssignmentIndex = index;
            currentAssignment = characterAssignments[index];
            showPlayerAssignmentModal = true;

            // Reset form state
            selectedProfileId = string.Empty;
            guestName = string.Empty;
            guestAgeRange = string.Empty;
            newProfileName = string.Empty;
            newProfileAgeRange = string.Empty;
            selectedAvatarMediaId = null;
            assignmentTab = "profiles";
            validationMessage = string.Empty;

            // Pre-load profiles when modal opens
            if (!availableProfiles.Any())
            {
                Logger.LogInformation("Pre-loading available profiles for character assignment");
                availableProfiles = await CharacterAssignmentService.GetAvailableProfilesAsync() ?? new List<UserProfile>();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening player assignment modal");
        }
    }

    private void ClosePlayerAssignment()
    {
        showPlayerAssignmentModal = false;
        currentAssignment = null;
        currentAssignmentIndex = -1;
    }

    private async Task HandlePlayerAssignmentResult(PlayerAssignmentModal.PlayerAssignmentResult result)
    {
        if (currentAssignmentIndex < 0 || currentAssignment == null) return;

        validationMessage = string.Empty;
        var playerAssignment = new PlayerAssignment();

        if (result.Tab == "profiles" && !string.IsNullOrEmpty(result.SelectedProfileId))
        {
            var profile = result.SelectedProfile ?? availableProfiles.FirstOrDefault(p => p.Id == result.SelectedProfileId);
            if (profile != null)
            {
                playerAssignment.Type = "Profile";
                playerAssignment.ProfileId = profile.Id;
                playerAssignment.ProfileName = profile.Name;
                playerAssignment.ProfileImage = null;
                playerAssignment.SelectedAvatarMediaId = profile.SelectedAvatarMediaId;
            }
        }
        else if (result.Tab == "new-profile" && !string.IsNullOrEmpty(result.NewProfileName) &&
                 !string.IsNullOrEmpty(result.NewProfileAgeRange))
        {
            var account = await AuthService.GetCurrentAccountAsync();
            if (account == null)
            {
                validationMessage = "Unable to create profile. Please try again.";
                StateHasChanged();
                return;
            }

            var profileRequest = new CreateUserProfileRequest
            {
                Name = result.NewProfileName,
                AgeGroup = result.NewProfileAgeRange,
                AccountId = account.Id,
                IsGuest = false,
                AvatarMediaId = result.SelectedAvatarMediaId,
                SelectedAvatarMediaId = result.SelectedAvatarMediaId
            };

            var createdProfile = await ApiClient.CreateProfileAsync(profileRequest);
            if (createdProfile != null)
            {
                playerAssignment.Type = "Profile";
                playerAssignment.ProfileId = createdProfile.Id;
                playerAssignment.ProfileName = createdProfile.Name;
                playerAssignment.ProfileImage = null;
                playerAssignment.SelectedAvatarMediaId = createdProfile.SelectedAvatarMediaId;

                availableProfiles.Add(createdProfile);
                Logger.LogInformation("Added new profile: {ProfileName} with avatar: {AvatarId}",
                    HashForLog(createdProfile.Name), createdProfile.SelectedAvatarMediaId);
            }
            else
            {
                validationMessage = "Failed to create profile. Please try again.";
                StateHasChanged();
                return;
            }
        }
        else if (result.Tab == "guest" && !string.IsNullOrEmpty(result.GuestName))
        {
            playerAssignment.Type = "Guest";
            playerAssignment.GuestName = result.GuestName;
            playerAssignment.GuestAgeRange = result.GuestAgeRange;
            playerAssignment.SaveAsProfile = false;
        }
        else if (result.Tab == "ai")
        {
            playerAssignment.Type = "AI";
            playerAssignment.GuestName = $"AI ({currentAssignment.CharacterName})";
            playerAssignment.ProfileName = $"AI ({currentAssignment.CharacterName})";
        }

        if (!string.IsNullOrEmpty(playerAssignment.Type))
        {
            characterAssignments[currentAssignmentIndex].PlayerAssignment = playerAssignment;
            ClosePlayerAssignment();
            StateHasChanged();
        }
    }

    private Task OnAvatarSelected(string mediaId)
    {
        selectedAvatarMediaId = mediaId;
        Logger.LogInformation("Avatar selected: {MediaId}", mediaId);
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void RemovePlayerAssignment(int index)
    {
        // Disallow removing assignments in toddler mode to prevent mixed selections
        if (IsToddlerScenario)
        {
            return;
        }

        characterAssignments[index].PlayerAssignment = null;
        StateHasChanged();
    }

    private async Task BeginSession()
    {
        // Do not allow starting the session until the initial assignment prompt is resolved
        if (showInitialAssignmentPrompt || !CanBeginSession) return;

        await CheckForWarningsAndContinue();
    }

    private async Task CheckForWarningsAndContinue(bool skipGuestWarning = false)
    {
        try
        {
            // Check for age group mismatches among assigned user profiles
            var showAgeGroupWarnings = await SettingsService.GetShowAgeGroupMismatchWarningAsync();
            if (showAgeGroupWarnings && HasAgeGroupMismatch())
            {
                showAgeGroupWarningModal = true;
                StateHasChanged();
                return;
            }

            // Check for replays
            var showReplayWarnings = await SettingsService.GetShowGameAlreadyPlayedWarningAsync();
            if (showReplayWarnings && await HasReplayMismatchAsync())
            {
                showReplayWarningModal = true;
                StateHasChanged();
                return;
            }

            // Check if only guests are assigned (no user profiles)
            if (!skipGuestWarning)
            {
                var assignedCharacters = characterAssignments
                    .Where(ca => !ca.IsUnused && ca.PlayerAssignment != null)
                    .ToList();

                var hasOnlyGuests = assignedCharacters.All(ca =>
                    ca.PlayerAssignment!.Type == "Guest" ||
                    (ca.PlayerAssignment!.Type == "AI" && string.IsNullOrEmpty(ca.PlayerAssignment!.ProfileId)));

                if (hasOnlyGuests)
                {
                    // Show guest warning modal unless the user opted out via global settings
                    var showGuestWarning = await SettingsService.GetShowGuestWarningAsync();
                    if (!showGuestWarning)
                    {
                        await ContinueWithGameSession();
                        return;
                    }
                    else
                    {
                        showGuestWarningModal = true;
                        StateHasChanged();
                        return;
                    }
                }
            }

            await ContinueWithGameSession();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error beginning session");
            isStartingSession = false;
            StateHasChanged();
        }
    }

    private bool HasAgeGroupMismatch()
    {
        mismatchedProfileNames.Clear();
        var scenarioAge = assignmentData?.Scenario?.AgeGroup;
        if (string.IsNullOrWhiteSpace(scenarioAge)) return false;

        var assignedProfileIds = characterAssignments
            .Where(ca => !ca.IsUnused && ca.PlayerAssignment?.Type == "Profile" && !string.IsNullOrEmpty(ca.PlayerAssignment.ProfileId))
            .Select(ca => ca.PlayerAssignment!.ProfileId!)
            .Distinct()
            .ToList();

        if (!assignedProfileIds.Any()) return false;

        var mismatched = availableProfiles
            .Where(p => assignedProfileIds.Contains(p.Id) && !string.Equals(p.AgeGroup, scenarioAge, StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (mismatched.Any())
        {
            mismatchedProfileNames = mismatched.Select(p => p.Name).ToList();
            return true;
        }

        return false;
    }

    private async Task ContinueAfterAgeGroupWarning()
    {
        showAgeGroupWarningModal = false;
        if (ageGroupDontShowAgain)
        {
            await SettingsService.SetShowAgeGroupMismatchWarningAsync(false);
        }
        await ContinueWithGameSession();
    }

    private void CancelAgeGroupWarning()
    {
        showAgeGroupWarningModal = false;
        ageGroupDontShowAgain = false; // reset checkbox
        StateHasChanged();
    }

    private async Task ContinueWithGameSession()
    {
        try
        {
            isStartingSession = true;
            StateHasChanged();

            Logger.LogInformation("Beginning session with character assignments for scenario: {ScenarioId}", ScenarioId);

            // Get current account
            var account = await AuthService.GetCurrentAccountAsync();
            if (account == null)
            {
                Logger.LogError("No account found for starting session");
                return;
            }

            // Create guest profiles if needed (for any remaining guests that weren't created immediately)
            var guestProfilesToCreate = characterAssignments
            .Where(ca => ca.PlayerAssignment?.Type == "Guest" && ca.PlayerAssignment.SaveAsProfile == true &&
            string.IsNullOrEmpty(ca.PlayerAssignment.ProfileId))
            .Select(ca => ca.PlayerAssignment!)
            .ToList();

            if (guestProfilesToCreate.Any())
            {
                Logger.LogInformation("Creating {Count} guest profiles", guestProfilesToCreate.Count);
                foreach (var guest in guestProfilesToCreate)
                {
                    var guestProfileRequest = new CreateGuestProfileRequest
                    {
                        Name = guest.GuestName!,
                        AgeRange = guest.GuestAgeRange,
                        AccountId = account.Id,
                        IsGuest = false // Saving as real profile
                    };

                    var createdProfile = await CharacterAssignmentService.CreateGuestProfileAsync(guestProfileRequest);
                    if (createdProfile != null)
                    {
                        guest.ProfileId = createdProfile.Id;
                        guest.ProfileName = createdProfile.Name;
                    }
                }
            }

            // Set character assignments in GameSessionService for text replacement
            GameSessionService.SetCharacterAssignments(characterAssignments);

            // Start the game session
            var request = new StartGameSessionRequest
            {
                ScenarioId = ScenarioId,
                AccountId = account.Id,
                ProfileId = account.UserProfileIds.FirstOrDefault() ?? "default-profile",
                CharacterAssignments = characterAssignments,
                TargetAgeGroup = assignmentData!.Scenario.AgeGroup,
                Scenario = assignmentData!.Scenario // Pass the full scenario for local session setup
            };

            Logger.LogInformation("Calling StartGameSessionWithAssignmentsAsync");
            var success = await CharacterAssignmentService.StartGameSessionWithAssignmentsAsync(request);

            if (success)
            {
                Logger.LogInformation("Session started successfully, navigating to {NavigationManagerBaseUri}game",
                NavigationManager.BaseUri);
                // Keep isStartingSession = true during navigation to prevent StopAllAsync in DisposeAsync
                NavigationManager.NavigateTo("/game");
                return; // skip setting isStartingSession = false in finally
            }
            else
            {
                Logger.LogError("Failed to start game session");
                isStartingSession = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error starting game session");
            isStartingSession = false;
        }
        finally
        {
            // Only reset if we are not navigating away for a success
            // If success was true, we returned early above.
            if (!isStartingSession)
            {
                StateHasChanged();
            }
        }
    }

    private async Task ContinueWithGuestAssignments()
    {
        showGuestWarningModal = false;

        // Persist preference if user checked the box in the modal
        if (dontShowGuestWarning)
        {
            await SettingsService.SetShowGuestWarningAsync(false);
        }

        if (pendingInitialGuestApplyAll)
        {
            // Apply guest assignment to all active characters, then close the initial prompt
            foreach (var ca in characterAssignments)
            {
                if (ca.IsUnused) continue;
                ca.PlayerAssignment = new PlayerAssignment
                {
                    Type = "Guest",
                    GuestName = guestName,
                    GuestAgeRange = guestAgeRange,
                    SaveAsProfile = false
                };
            }

            pendingInitialGuestApplyAll = false;
            showInitialAssignmentPrompt = false;

            // For toddler scenarios, auto-start immediately after choosing guest
            if (IsToddlerScenario)
            {
                Logger.LogInformation("Toddler scenario: Auto-starting with guest {GuestName}", HashForLog(guestName));
                await CheckForWarningsAndContinue(true);
                return;
            }

            StateHasChanged();
            return;
        }

        await ContinueWithGameSession();
    }

    private void CancelGuestWarning()
    {
        showGuestWarningModal = false;
        // Reset modal checkbox when cancelling to avoid accidental persistence
        dontShowGuestWarning = false;
        if (pendingInitialGuestApplyAll)
        {
            // Keep the initial prompt open; do not apply guest assignments
            pendingInitialGuestApplyAll = false;
            showInitialAssignmentPrompt = true; // Show it back so they can change selection
        }
        StateHasChanged();
    }

