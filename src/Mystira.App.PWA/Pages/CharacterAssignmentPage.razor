    private async Task PlayAudio(string audioUrl)
    {
        try
        {
            if (isPlayingAudio == audioUrl)
            {
                await AudioOrchestrator.StopNarrationAsync(audioUrl, unduckMusic: false);
                isPlayingAudio = null;
            }
            else
            {
                if (!string.IsNullOrEmpty(isPlayingAudio))
                {
                    await AudioOrchestrator.StopNarrationAsync(isPlayingAudio, unduckMusic: false);
                }

                await AudioOrchestrator.PlayNarrationAsync(audioUrl, duckMusic: false);
                isPlayingAudio = audioUrl;
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error playing audio: {ex.Message}");
        }
        finally
        {
            StateHasChanged();
        }
    }

    private bool CanBeginSession
    {
        get
        {
            // Block starting while the initial assignment prompt is still visible
            if (showInitialAssignmentPrompt)
            {
                return false;
            }

            return characterAssignments.All(ca =>
                ca.IsUnused || (ca.PlayerAssignment != null && !string.IsNullOrEmpty(ca.PlayerAssignment.Type)));
        }
    }

    private bool HasUnassignedCharacters
    {
        get
        {
            return characterAssignments.Any(ca =>
                !ca.IsUnused && ca.PlayerAssignment == null);
        }
    }

    private int UnassignedCount
    {
        get
        {
            return characterAssignments.Count(ca =>
                !ca.IsUnused && ca.PlayerAssignment == null);
        }
    }

    private void FillRemainingWithGuests()
    {
        if (IsToddlerScenario)
        {
            // Prevent changing assignments in toddler mode
            return;
        }
        foreach (var assignment in characterAssignments)
        {
            if (!assignment.IsUnused && assignment.PlayerAssignment == null)
            {
                assignment.PlayerAssignment = new PlayerAssignment
                {
                    Type = "Guest",
                    ProfileName = $"{assignment.CharacterName}",
                    GuestName = $"{assignment.CharacterName}"
                };
            }
        }
        StateHasChanged();
        Logger.LogInformation("Filled {Count} unassigned characters with Guest players", UnassignedCount);
    }

    private static string HashForLog(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "[empty]";
        var bytes = System.Security.Cryptography.SHA256.HashData(System.Text.Encoding.UTF8.GetBytes(id));
        return Convert.ToHexString(bytes, 0, 4).ToLowerInvariant();
    }

    private async Task<bool> HasReplayMismatchAsync()
    {
        replayingProfileNames.Clear();

        var assignedProfileIds = characterAssignments
            .Where(ca => !ca.IsUnused && ca.PlayerAssignment?.Type == "Profile" && !string.IsNullOrEmpty(ca.PlayerAssignment.ProfileId))
            .Select(ca => ca.PlayerAssignment!.ProfileId!)
            .Distinct()
            .ToList();

        if (!assignedProfileIds.Any()) return false;

        foreach (var profileId in assignedProfileIds)
        {
            var sessions = await ApiClient.GetSessionsByProfileAsync(profileId);
            // Check if any completed session exists for this scenario
            if (sessions != null && sessions.Any(s => s.ScenarioId == ScenarioId && s.IsCompleted))
            {
                var profile = availableProfiles.FirstOrDefault(p => p.Id == profileId);
                if (profile != null)
                {
                    replayingProfileNames.Add(profile.Name);
                }
            }
        }

        return replayingProfileNames.Any();
    }

    private async Task ContinueAfterReplayWarning()
    {
        showReplayWarningModal = false;
        if (replayDontShowAgain)
        {
            await SettingsService.SetShowGameAlreadyPlayedWarningAsync(false);
        }
        await ContinueWithGameSession();
    }

    private void CancelReplayWarning()
    {
        showReplayWarningModal = false;
        replayDontShowAgain = false; // reset checkbox
        StateHasChanged();
    }
