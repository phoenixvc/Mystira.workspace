@page "/scenario-dominator-path-analysis"
@using Mystira.StoryGenerator.Web.Models
@using Mystira.StoryGenerator.Contracts.Chat
@using System.Text
@using System.Linq
@inject WebScenarioDominatorPathAnalysisService AnalysisService
@inject ILogger<ScenarioDominatorPathAnalysis> Logger
@inject IChatSessionService ChatSessionService
@inject IAiModelSettingsService ModelSettingsService

<PageTitle>Scenario Dominator Path Analysis</PageTitle>

<div class="path-analysis-container">
    <div class="page-header">
        <h1>Scenario Dominator Path Analysis</h1>
        <NavLink class="back-link" href="/story-generator" title="Back to Home">← Back</NavLink>
    </div>

    <div class="controls-section">
        <div class="action-buttons">
            <button @onclick="AnalyzePath" disabled="@isAnalyzing">
                @if (isAnalyzing)
                {
                    <span>Analyzing...</span>
                }
                else
                {
                    <span>Analyze Story Paths</span>
                }
            </button>
        </div>

        <!-- Provider / Model selection -->
        <div class="model-selects">
            <div class="select-group">
                <label for="providerSelect">Provider</label>
                <select id="providerSelect" @bind="selectedProvider">
                    @foreach (var p in providerOptions)
                    {
                        <option value="@p">@p</option>
                    }
                </select>
            </div>
            <div class="select-group">
                <label for="modelSelect">Model</label>
                <select id="modelSelect" @bind="selectedModel">
                    @foreach (var m in GetModelsForProvider(selectedProvider))
                    {
                        <option value="@m.Id">@m.DisplayName (@m.Id)</option>
                    }
                </select>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(evaluationError))
        {
            <div class="error-message">
                <p>@evaluationError</p>
            </div>
        }
    </div>

    @if (pathResults != null && pathResults.Count > 0)
    {
        <div class="results-section">
            <div class="results-header">
                <h2>Path Analysis Results (@pathResults.Count @(pathResults.Count == 1 ? "path" : "paths"))</h2>
                <button class="export-button" @onclick="ExportToCsv" title="Export all results to CSV">
                    <span>📥 Export to CSV</span>
                </button>
            </div>

            <div class="paths-grid">
                @foreach (var pathResult in pathResults)
                {
                    <div class="path-card">
                        <div class="card-header">
                            <h3 class="path-title">Path</h3>
                            @if (pathResult.Result != null && !string.IsNullOrEmpty(pathResult.Result.OverallAssessment))
                            {
                                <span class="assessment-badge @GetAssessmentClass(pathResult.Result.OverallAssessment)">
                                    @FormatAssessment(pathResult.Result.OverallAssessment)
                                </span>
                            }
                        </div>

                        <div class="card-body">
                            <div class="path-sequence">
                                <p><strong>Path:</strong></p>
                                <div class="path-nodes">
                                    @foreach (var part in pathResult.Path.Split(" -> "))
                                    {
                                        <span class="path-node">@part</span>
                                    }
                                </div>
                            </div>

                            @if (pathResult.Result?.Issues != null && pathResult.Result.Issues.Count > 0)
                            {
                                <div class="issues-list">
                                    <h4>Issues (@pathResult.Result.Issues.Count)</h4>
                                    @foreach (var issue in pathResult.Result.Issues)
                                    {
                                        <div class="issue-item">
                                            <div class="issue-header">
                                                <span class="severity-badge @GetSeverityClass(issue.Severity)">@issue.Severity</span>
                                                <span class="category-badge">@issue.Category</span>
                                            </div>

                                            <div class="issue-summary">
                                                <p><strong>Summary:</strong> @issue.Summary</p>
                                            </div>

                                            @if (!string.IsNullOrEmpty(issue.SuggestedFix))
                                            {
                                                <div class="issue-fix">
                                                    <p><strong>Suggested Fix:</strong></p>
                                                    <p>@issue.SuggestedFix</p>
                                                </div>
                                            }

                                            @if (issue.SceneIds != null && issue.SceneIds.Count > 0)
                                            {
                                                <div class="issue-scenes">
                                                    <p><strong>Scenes:</strong> @string.Join(", ", issue.SceneIds)</p>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="no-issues">
                                    <p>✓ No issues found in this path</p>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (evaluationCompleted && (pathResults == null || pathResults.Count == 0))
    {
        <div class="success-message">
            <p>Analysis completed. No paths were generated or analyzed.</p>
        </div>
    }
</div>

