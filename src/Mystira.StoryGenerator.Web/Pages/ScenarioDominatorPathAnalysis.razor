@code {
    private List<DominatorPathAnalysisResult>? pathResults;
    private bool isAnalyzing = false;
    private bool evaluationCompleted = false;
    private string evaluationError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await ChatSessionService.EnsureInitializedAsync();

        // Load available providers/models
        await ModelSettingsService.InitializeAsync();
        var models = await ModelSettingsService.GetAvailableModelsAsync();
        allModels = models.ToList();
        providerOptions = allModels
            .Select(m => m.Provider)
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(p => p)
            .ToList();

        // Defaults
        selectedProvider = providerOptions.FirstOrDefault() ?? string.Empty;
        selectedModel = GetModelsForProvider(selectedProvider).FirstOrDefault()?.Id ?? string.Empty;
    }

    private async Task AnalyzePath()
    {
        isAnalyzing = true;
        evaluationError = string.Empty;
        evaluationCompleted = false;

        try
        {
            await ChatSessionService.EnsureInitializedAsync();
            var ensured = await EnsureActiveSessionWithSnapshotAsync();
            var session = ChatSessionService.CurrentSession;
            if (!ensured || session == null || string.IsNullOrWhiteSpace(session.YamlSnapshot))
            {
                evaluationError = "No active chat with a story snapshot was found. Open or import a story in the chat, then try Analyze again.";
                return;
            }

            var storyJson = JsonYamlConverter.ToJson(session.YamlSnapshot);

            var snapshot = new StorySnapshot
            {
                StoryId = session.Id,
                StoryVersion = Math.Max(1, session.Messages?.Count ?? 1),
                Content = storyJson
            };

            var request = new EvaluateDominatorPathConsistencyRequest
            {
                CurrentStory = snapshot
            };

            var result = await AnalysisService.EvaluateAsync(request);

            if (result.Success)
            {
                pathResults = result.PathResults;
                evaluationCompleted = true;
            }
            else
            {
                evaluationError = result.Error ?? "Unknown error occurred";
                Logger.LogError("Path analysis evaluation failed: {Error}", evaluationError);
            }
        }
        catch (Exception ex)
        {
            evaluationError = $"Error: {ex.Message}";
            Logger.LogError(ex, "Exception during path analysis evaluation");
        }
        finally
        {
            isAnalyzing = false;
        }
    }

    private async Task<bool> EnsureActiveSessionWithSnapshotAsync()
    {
        var session = ChatSessionService.CurrentSession;
        if (session != null && !string.IsNullOrWhiteSpace(session.YamlSnapshot))
            return true;

        try
        {
            var history = await ChatSessionService.GetSessionHistoryAsync();
            var candidate = history
                .OrderByDescending(h => h.UpdatedAt)
                .FirstOrDefault(h => h.HasYamlSnapshot);

            if (candidate != null)
            {
                await ChatSessionService.LoadSessionAsync(candidate.Id);
                session = ChatSessionService.CurrentSession;
                return session != null && !string.IsNullOrWhiteSpace(session.YamlSnapshot);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to ensure active session with snapshot");
        }

        return false;
    }

    private string FormatAssessment(string assessment)
    {
        return assessment switch
        {
            "ok" => "✓ OK",
            "has_minor_issues" => "⚠ Minor Issues",
            "has_major_issues" => "✗ Major Issues",
            "broken" => "✗ Broken",
            _ => assessment
        };
    }

    private string GetAssessmentClass(string assessment)
    {
        return assessment switch
        {
            "ok" => "ok",
            "has_minor_issues" => "minor",
            "has_major_issues" => "major",
            "broken" => "broken",
            _ => string.Empty
        };
    }

    private string GetSeverityClass(string severity)
    {
        return severity?.ToLower() ?? string.Empty;
    }

    private async Task ExportToCsv()
    {
        if (pathResults == null || pathResults.Count == 0)
        {
            evaluationError = "No results to export";
            return;
        }

        try
        {
            var csv = new StringBuilder();
            csv.AppendLine("Path,Scene IDs,Issue ID,Severity,Category,Summary,Suggested Fix,Overall Assessment");

            foreach (var pathResult in pathResults)
            {
                var pathStr = EscapeCsv(pathResult.Path);

                if (pathResult.Result?.Issues != null && pathResult.Result.Issues.Count > 0)
                {
                    foreach (var issue in pathResult.Result.Issues)
                    {
                        var sceneIds = EscapeCsv(string.Join("; ", issue.SceneIds ?? new List<string>()));
                        var severity = EscapeCsv(issue.Severity);
                        var category = EscapeCsv(issue.Category);
                        var summary = EscapeCsv(issue.Summary);
                        var suggestedFix = EscapeCsv(issue.SuggestedFix);
                        var assessment = EscapeCsv(pathResult.Result?.OverallAssessment ?? string.Empty);

                        csv.AppendLine($"{pathStr},{sceneIds},,{severity},{category},{summary},{suggestedFix},{assessment}");
                    }
                }
                else
                {
                    var assessment = EscapeCsv(pathResult.Result?.OverallAssessment ?? string.Empty);
                    csv.AppendLine($"{pathStr},,,,,,No issues found,{assessment}");
                }
            }

            var csvText = csv.ToString();
            try
            {
                await JS.InvokeVoidAsync("downloadFileText",
                    "scenario_path_analysis_results.csv",
                    csvText,
                    "text/csv;charset=utf-8");
            }
            catch
            {
                // Fallback: call generic downloader with plain text (no base64)
                await JS.InvokeVoidAsync("downloadFile",
                    "scenario_path_analysis_results.csv",
                    csvText,
                    "text/csv;charset=utf-8");
            }
        }
        catch (Exception ex)
        {
            evaluationError = $"Error exporting to CSV: {ex.Message}";
            Logger.LogError(ex, "Failed to export to CSV");
        }
    }

    private string EscapeCsv(string value)
    {
        if (string.IsNullOrEmpty(value))
            return string.Empty;

        if (value.Contains(",") || value.Contains("\"") || value.Contains("\n"))
        {
            return "\"" + value.Replace("\"", "\"\"") + "\"";
        }

        return value;
    }

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    // Provider/Model dropdown state
    private List<AiModelDefinition> allModels = new();
    private List<string> providerOptions = new();
    private string selectedProvider = string.Empty;
    private string selectedModel = string.Empty;

    private IEnumerable<AiModelDefinition> GetModelsForProvider(string provider)
    {
        if (string.IsNullOrWhiteSpace(provider)) return Enumerable.Empty<AiModelDefinition>();
        return allModels.Where(m => string.Equals(m.Provider, provider, StringComparison.OrdinalIgnoreCase));
    }
}
