    }

    .confidence-low {
        background: #f8d7da;
        color: #721c24;
    }

    .issue-description {
        margin: 1rem 0;
        padding: 0.75rem;
        background: #f8f9fa;
        border-left: 3px solid #667eea;
        border-radius: 4px;
    }

    .issue-description p {
        margin: 0;
        color: #333;
        line-height: 1.5;
    }

    .evidence {
        margin-top: 1rem;
        padding: 0.75rem;
        background: #f0f0f0;
        border-radius: 4px;
        font-size: 0.9rem;
    }

    .evidence p {
        margin: 0;
        color: #555;
    }

    .evidence em {
        color: #667eea;
        font-style: italic;
    }

    @@media (max-width: 1024px) {
        .provider-config {
            grid-template-columns: 1fr;
        }

        .filters-section {
            grid-template-columns: 1fr 1fr;
        }

        .issues-grid {
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .continuity-container {
            padding: 1rem;
        }

        .filters-section {
            grid-template-columns: 1fr;
        }

        .issues-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
