        background: #ffd700;
        color: #333;
    }

    .badge-not-introduced {
        background: #ff6b6b;
        color: white;
    }

    .badge-default {
        background: #ccc;
        color: #333;
    }

    .card-body {
        padding: 1rem;
    }

    .issue-details {
        margin-bottom: 1rem;
    }

    .issue-details p {
        margin: 0.5rem 0;
