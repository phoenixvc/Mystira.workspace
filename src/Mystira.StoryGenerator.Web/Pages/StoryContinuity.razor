    .card-header h3 {
        margin: 0;
        font-size: 1.1rem;
        color: #333;
        word-break: break-word;
    }

    .badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        white-space: nowrap;
    }

