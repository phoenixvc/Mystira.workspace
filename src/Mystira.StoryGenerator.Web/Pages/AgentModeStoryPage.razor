@page "/story/agent"
@using Mystira.StoryGenerator.Web.Services
@using Mystira.StoryGenerator.Api.Models
@using Mystira.StoryGenerator.Application.Infrastructure.Agents
@using Mystira.StoryGenerator.Contracts.Models
@using System.Text.Json
@inject IAgentSessionService sessionService
@inject ILogger<AgentModeStoryPage> logger

<PageTitle>AI Story Generator</PageTitle>

<div class="agent-story-container">
    @if (!sessionStarted)
    {
        <AgentModePromptForm
            OnStartSession="HandleStartSession"
            IsLoading="isGenerating" />
    }
    else if (currentSession != null)
    {
        <div class="session-container">
            <AgentModeProgressPanel
                Session="currentSession"
                EvaluationReport="lastEvaluation"
                RubricSummary="currentSession?.RubricSummary"
                Events="streamEvents" />

            @if (currentSession.Stage == "Evaluated" || currentSession.Stage == "RefinementRequested")
            {
                <AgentModeRefinementPanel
                    Session="currentSession"
                    OnRefine="HandleRefine"
                    OnProceedToRubric="HandleProceedToRubric"
                    OnComplete="HandleComplete"
                    IsLoading="isRefining" />
            }

            @if (!string.IsNullOrWhiteSpace(currentSession.CurrentStoryJson) &&
                 (currentSession.Stage == "Validating" || currentSession.Stage == "Evaluating" ||
                  currentSession.Stage == "Evaluated" || currentSession.Stage == "RefinementRequested" ||
                  currentSession.Stage == "Complete"))
            {
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                    <div>
                        <StoryDisplayPanel Story="@currentSession.CurrentStoryJson" />
                    </div>
                    <div>
                        <YamlPreviewPanel
                            YamlContent="@currentSession.CurrentStoryYaml"
                            ValidationResult="null" />
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">
                    <strong>Error:</strong> @errorMessage
                </div>
            }
        </div>
    }
</div>

@code {
    private bool sessionStarted = false;
    private bool isGenerating = false;
    private bool isRefining = false;
    private SessionStateResponse? currentSession;
    private EvaluationReport? lastEvaluation;
    private List<AgentStreamEvent> streamEvents = new();
    private string? errorMessage;
    private CancellationTokenSource? streamCts;

    private async Task HandleStartSession(StartSessionRequest request)
    {
        try
        {
            errorMessage = null;
            isGenerating = true;

            var startResponse = await sessionService.StartSessionAsync(request);
            logger.LogInformation("Session started: {SessionId}", startResponse.SessionId);

            // Initialize session state from start response
            currentSession = new SessionStateResponse
            {
                SessionId = startResponse.SessionId,
                ThreadId = startResponse.ThreadId,
                Stage = startResponse.Stage,
                IterationCount = 0,
                CurrentStoryJson = string.Empty,
                ErrorMessage = null
            };

            sessionStarted = true;
            StateHasChanged();

            // Start SSE stream
            streamCts = new CancellationTokenSource();
            _ = StreamEventsAsync(startResponse.SessionId);

            // Poll for generation completion
            await WaitForGenerationAsync(startResponse.SessionId);

            isGenerating = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error starting session");
            errorMessage = $"Failed to start session: {ex.Message}";
            isGenerating = false;
            StateHasChanged();
        }
    }

    private async Task StreamEventsAsync(string sessionId)
    {
        try
        {
            await foreach (var evt in sessionService.SubscribeToStreamAsync(sessionId, streamCts?.Token ?? default))
            {
                streamEvents.Add(evt);
                logger.LogDebug("Received event: {EventType}", evt.Type);

                // Handle specific event types
                if (evt.Type == AgentStreamEvent.EventType.EvaluationPassed ||
                    evt.Type == AgentStreamEvent.EventType.EvaluationFailed)
                {
                    // Refresh session to get latest evaluation
                    await RefreshSessionAsync(sessionId);
                }

                StateHasChanged();
            }
        }
        catch (OperationCanceledException)
        {
            logger.LogInformation("SSE stream cancelled");
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error streaming events");
        }
    }

    private async Task WaitForGenerationAsync(string sessionId)
    {
        try
        {
            // Poll for story generation completion
            var maxAttempts = 120; // 10 minutes (120 attempts * 5 seconds)
            var attempt = 0;

            while (attempt < maxAttempts)
            {
                await Task.Delay(5000); // Poll every 5 seconds
                currentSession = await sessionService.GetSessionAsync(sessionId);
                StateHasChanged();

                if (currentSession.Stage == "Validating" || currentSession.Stage == "Evaluating")
                {
                    break;
                }

                // Check if the session has failed
                if (currentSession.Stage == "Failed")
                {
                    errorMessage = currentSession.ErrorMessage ?? "Story generation failed. Please try again.";
                    logger.LogError("Session {SessionId} failed: {ErrorMessage}", sessionId, errorMessage);
                    return;
                }

                attempt++;
            }

            // Check for timeout
            if (attempt >= maxAttempts && currentSession?.Stage != "Validating" && currentSession?.Stage != "Evaluating")
            {
                errorMessage = "Story generation timed out after 10 minutes. Please try again.";
                logger.LogWarning("Session {SessionId} timed out", sessionId);
                return;
            }

            // If we reached Validating stage, trigger evaluation
            if (currentSession?.Stage == "Validating")
            {
                logger.LogInformation("Story validation complete, starting evaluation");
                await EvaluateStoryAsync(sessionId);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error waiting for generation");
            errorMessage = $"Error during generation: {ex.Message}";
        }
    }

    private async Task EvaluateStoryAsync(string sessionId)
    {
        try
        {
            // Start the evaluation (this will set backend to "Evaluating" state)
            var evaluateTask = sessionService.EvaluateAsync(sessionId);

            // Give backend time to set state to "Evaluating" and publish event
            await Task.Delay(500);

            // Refresh session to show "Evaluating" state
            await RefreshSessionAsync(sessionId);
            StateHasChanged();

            // Wait for evaluation to complete
            var evalResponse = await evaluateTask;
            lastEvaluation = evalResponse.EvaluationReport;

            // Refresh session state to show final evaluation result
            await RefreshSessionAsync(sessionId);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error evaluating story");
            errorMessage = $"Error during evaluation: {ex.Message}";
        }
    }

    private async Task HandleRefine(RefineRequest request)
    {
        if (currentSession == null)
            return;

        try
        {
            errorMessage = null;
            isRefining = true;
            StateHasChanged();

            await sessionService.RefineAsync(currentSession.SessionId, request);

            // Wait for refinement to complete
            await WaitForRefinementAsync(currentSession.SessionId);

            isRefining = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error refining story");
            errorMessage = $"Failed to refine story: {ex.Message}";
            isRefining = false;
            StateHasChanged();
        }
    }

    private async Task WaitForRefinementAsync(string sessionId)
    {
        try
        {
            var maxAttempts = 120; // 10 minutes (120 attempts * 5 seconds)
            var attempt = 0;

            while (attempt < maxAttempts)
            {
                await Task.Delay(5000); // Poll every 5 seconds
                currentSession = await sessionService.GetSessionAsync(sessionId);
                StateHasChanged();

                // Break when refinement completes and reaches validation/evaluation stage
                // Also break if already evaluated (in case refinement was very fast)
                if (currentSession.Stage == "Validating" ||
                    currentSession.Stage == "Evaluating" ||
                    currentSession.Stage == "Evaluated" ||
                    currentSession.Stage == "RefinementRequested")
                {
                    break;
                }

                // Check if the session has failed
                if (currentSession.Stage == "Failed")
                {
                    errorMessage = currentSession.ErrorMessage ?? "Story refinement failed. Please try again.";
                    logger.LogError("Session {SessionId} failed during refinement: {ErrorMessage}", sessionId, errorMessage);
                    return;
                }

                attempt++;
            }

            // Check for timeout
            if (attempt >= maxAttempts)
            {
                errorMessage = "Story refinement timed out after 10 minutes. Please try again.";
                logger.LogWarning("Session {SessionId} refinement timed out", sessionId);
                return;
            }

            // Trigger re-evaluation if we're at Validating stage
            // If already Evaluated/RefinementRequested, evaluation already happened
            if (currentSession?.Stage == "Validating")
            {
                logger.LogInformation("Refinement complete, starting re-evaluation for session {SessionId}", sessionId);
                await EvaluateStoryAsync(sessionId);
            }
            else if (currentSession?.Stage == "Evaluating")
            {
                logger.LogInformation("Refinement complete, evaluation already in progress for session {SessionId}", sessionId);
                // Wait for evaluation to complete
                await WaitForEvaluationAsync(sessionId);
            }
            else
            {
                logger.LogInformation("Refinement and evaluation complete for session {SessionId}, stage: {Stage}",
                    sessionId, currentSession?.Stage);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error waiting for refinement");
            errorMessage = $"Error during refinement: {ex.Message}";
        }
    }

    private async Task WaitForEvaluationAsync(string sessionId)
    {
        try
        {
            var maxAttempts = 120; // 10 minutes
            var attempt = 0;

            while (attempt < maxAttempts)
            {
                await Task.Delay(5000);
                currentSession = await sessionService.GetSessionAsync(sessionId);
                StateHasChanged();

                if (currentSession.Stage == "Evaluated" ||
                    currentSession.Stage == "RefinementRequested" ||
                    currentSession.Stage == "Failed")
                {
                    break;
                }

                attempt++;
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error waiting for evaluation");
        }
    }

    private async Task HandleProceedToRubric()
    {
        if (currentSession == null)
            return;

        try
        {
            errorMessage = null;
            isRefining = true;
            StateHasChanged();

            // Call rubric generation endpoint
            currentSession = await sessionService.GenerateRubricAsync(currentSession.SessionId);

            logger.LogInformation("Rubric generated for session {SessionId}", currentSession.SessionId);

            isRefining = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error generating rubric");
            errorMessage = $"Failed to generate rubric: {ex.Message}";
            isRefining = false;
            StateHasChanged();
        }
    }

    private async Task HandleComplete()
    {
        if (currentSession == null)
            return;

        try
        {
            errorMessage = null;
            isRefining = true;
            StateHasChanged();

            // Call complete endpoint
            currentSession = await sessionService.CompleteAsync(currentSession.SessionId);

            logger.LogInformation("Session {SessionId} completed successfully", currentSession.SessionId);

            isRefining = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error completing session");
            errorMessage = $"Failed to complete session: {ex.Message}";
            isRefining = false;
            StateHasChanged();
        }
    }

    private async Task RefreshSessionAsync(string sessionId)
    {
        try
        {
            currentSession = await sessionService.GetSessionAsync(sessionId);

            if (currentSession.LastEvaluationReport != null)
            {
                lastEvaluation = currentSession.LastEvaluationReport;
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error refreshing session");
        }
    }

    public void Dispose()
    {
        streamCts?.Cancel();
        streamCts?.Dispose();
    }
}
