@using Mystira.StoryGenerator.Domain.Agents
@using Mystira.StoryGenerator.Application.Infrastructure.Agents
@using Mystira.StoryGenerator.Contracts.Models

<div class="progress-panel">
    @if (Session != null && Session.IterationCount > 0)
    {
        <div class="iteration-badge">
            <strong>Iteration:</strong> @Session.IterationCount
        </div>
    }

    <div class="timeline">
        @foreach (var phase in phases)
        {
            <div class="timeline-item @GetPhaseStatus(phase)">
                <div class="timeline-marker">
                    @if (currentPhase == "Failed" && phase == currentPhase)
                    {
                        <span>❌</span>
                    }
                    else if (IsEvaluatingCompleteWaitingForUser(phase))
                    {
                        <span>✅</span>
                    }
                    else if (phase == "Complete" && currentPhase == "Complete")
                    {
                        <span>✅</span>
                    }
                    else if (phase == "Rubric" && currentPhase == "Rubric" && RubricSummary != null)
                    {
                        <span>✅</span>
                    }
                    else if (phase == currentPhase)
                    {
                        <span class="spinner">⏳</span>
                    }
                    else if (IsPhaseComplete(phase))
                    {
                        <span>✅</span>
                    }
                    else
                    {
                        <span>○</span>
                    }
                </div>
                <div class="timeline-label">@phase</div>
            </div>
        }
    </div>

    @if (EvaluationReport != null)
    {
        <div class="evaluation-scorecard">
            <h3>Evaluation Results</h3>

            <div class="score-row">
                <label>Safety Gate</label>
                <span class="@(EvaluationReport.SafetyGatePassed ? "pass" : "fail")">
                    @(EvaluationReport.SafetyGatePassed ? "✅ Passed" : "⚠️ Failed")
                </span>
            </div>

            <div class="score-row">
                <label>Axes Alignment</label>
                <ProgressBar Value="@EvaluationReport.AxesAlignmentScore" Max="1.0" />
            </div>

            <div class="score-row">
                <label>Dev Principles</label>
                <ProgressBar Value="@EvaluationReport.DevPrinciplesScore" Max="1.0" />
            </div>

            <div class="score-row">
                <label>Narrative Logic</label>
                <ProgressBar Value="@EvaluationReport.NarrativeLogicScore" Max="1.0" />
            </div>

            @if (EvaluationReport.Findings.Any())
            {
                <div class="findings">
                    <h4>Key Findings</h4>
                    @foreach (var category in EvaluationReport.Findings)
                    {
                        @if (category.Value.Any())
                        {
                            <div class="finding-category">
                                <strong>@category.Key</strong>
                                <ul>
                                    @foreach (var finding in category.Value)
                                    {
                                        <li>@finding</li>
                                    }
                                </ul>
                            </div>
                        }
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(EvaluationReport.Recommendation))
            {
                <div class="recommendation">
                    <strong>Next Steps:</strong> @EvaluationReport.Recommendation
                </div>
            }
        </div>
    }

    @if (RubricSummary != null)
    {
        <div class="rubric-summary evaluation-scorecard">
            <h3>📊 Story Quality Rubric</h3>

            <div class="rubric-header">
                <div class="@(RubricSummary.ReadyForPublish ? "ready-badge" : "needs-work-badge")">
                    @(RubricSummary.ReadyForPublish ? "✅ Ready for Publish" : "⚠️ Needs Refinement")
                </div>
            </div>

            @if (!string.IsNullOrEmpty(RubricSummary.Summary))
            {
                <div class="rubric-section">
                    <h4>Summary</h4>
                    <p>@RubricSummary.Summary</p>
                </div>
            }

            @if (RubricSummary.Strengths.Any())
            {
                <div class="rubric-section">
                    <h4>✨ What's Working</h4>
                    <ul class="strength-list">
                        @foreach (var strength in RubricSummary.Strengths)
                        {
                            <li>@strength</li>
                        }
                    </ul>
                </div>
            }

            @if (RubricSummary.Concerns.Any())
            {
                <div class="rubric-section">
                    <h4>🔍 What Needs Work</h4>
                    <ul class="concern-list">
                        @foreach (var concern in RubricSummary.Concerns)
                        {
                            <li>@concern</li>
                        }
                    </ul>
                </div>
            }

            @if (RubricSummary.SuggestedFocus.Any())
            {
                <div class="rubric-section">
                    <h4>🎯 Next Steps</h4>
                    <ul class="focus-list">
                        @foreach (var focus in RubricSummary.SuggestedFocus)
                        {
                            <li>@focus</li>
                        }
                    </ul>
                </div>
            }

            <div class="button-group mt-4" style="display: flex; gap: 0.75rem;">
                <button @onclick="Refine" class="btn-primary" style="flex: 1;">
                    ✨ Refine Story
                </button>
                <button @onclick="Complete" class="btn-secondary" style="flex: 1;">
                    ✅ Complete Session
                </button>
            </div>
        </div>
    }

    @if (Events.Any())
    {
        <div class="event-log">
            <h4>Progress Log</h4>
            <div class="events">
                @foreach (var evt in Events.TakeLast(10).Reverse())
                {
                    <div class="event @evt.Type.ToString().ToLower()">
                        <span class="timestamp">@evt.Timestamp.ToString("HH:mm:ss")</span>
                        <span class="type">@FormatEventType(evt.Type)</span>
                        @if (evt.Type == AgentStreamEvent.EventType.PhaseStarted && !string.IsNullOrEmpty(evt.Phase))
                        {
                            <span class="phase">@evt.Phase</span>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (Session != null)
    {
        <div class="metadata">
            Iteration: @Session.IterationCount | Tokens: ~@(Session.IterationCount * 1500)
        </div>

        @if (Session.Stage == "Failed" && !string.IsNullOrEmpty(Session.ErrorMessage))
        {
            <div class="alert alert-danger mt-3">
                <strong>Error:</strong> @Session.ErrorMessage
            </div>
        }

        @if ((Session.Stage == "Generating" || Session.Stage == "Refining") && !string.IsNullOrEmpty(Session.CurrentStoryJson))
        {
            <div class="current-generation mt-3">
                <h4>Current Generation Progress</h4>
                <div class="story-preview">
                    <pre class="json-preview">@Session.CurrentStoryJson</pre>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public SessionStateResponse? Session { get; set; }
    [Parameter] public EvaluationReport? EvaluationReport { get; set; }
    [Parameter] public RubricSummary? RubricSummary { get; set; }
    [Parameter] public List<AgentStreamEvent> Events { get; set; } = new();
    [Parameter] public EventCallback OnRefineRequested { get; set; }
    [Parameter] public EventCallback OnCompleteRequested { get; set; }

    private string currentPhase = "Writing";
    private List<string> phases = new() { "Writing", "Validating", "Evaluating", "Rubric", "Complete" };

    private async Task Refine() => await OnRefineRequested.InvokeAsync();
    private async Task Complete() => await OnCompleteRequested.InvokeAsync();

    private string GetPhaseStatus(string phase)
    {
        // For Rubric phase, if we're currently in it, it should show as active (spinner)
        if (phase == "Rubric" && currentPhase == "Rubric")
        {
            // If the rubric is already generated, it should show as complete
            return RubricSummary != null ? "complete" : "active";
        }

        // For Complete phase
        if (phase == "Complete" && currentPhase == "Complete")
            return "complete";

        return phase == currentPhase ? "active" : IsPhaseComplete(phase) ? "complete" : "pending";
    }

    private bool IsPhaseComplete(string phase)
    {
        var phaseIndex = phases.IndexOf(phase);
        var currentIndex = phases.IndexOf(currentPhase);
        return phaseIndex < currentIndex;
    }

    private bool IsEvaluatingCompleteWaitingForUser(string phase)
    {
        // When in Evaluated or RefinementRequested state, Evaluating phase should show as complete (✅) not active (⏳)
        return phase == "Evaluating" &&
               Session != null &&
               (Session.Stage == "Evaluated" || Session.Stage == "RefinementRequested");
    }

    private string FormatEventType(AgentStreamEvent.EventType type)
    {
        return type switch
        {
            AgentStreamEvent.EventType.PhaseStarted => "Phase Started",
            AgentStreamEvent.EventType.GenerationComplete => "Generation Complete",
            AgentStreamEvent.EventType.ValidationFailed => "Validation Failed",
            AgentStreamEvent.EventType.EvaluationPassed => "Evaluation Passed",
            AgentStreamEvent.EventType.EvaluationFailed => "Evaluation Failed",
            AgentStreamEvent.EventType.RefinementComplete => "Refinement Complete",
            AgentStreamEvent.EventType.RubricGenerated => "Rubric Generated",
            AgentStreamEvent.EventType.MaxIterationsReached => "Max Iterations Reached",
            AgentStreamEvent.EventType.Error => "Error",
            AgentStreamEvent.EventType.TokenUsageUpdate => "Token Usage Update",
            _ => type.ToString()
        };
    }

    protected override void OnParametersSet()
    {
        // Update current phase based on session stage
        if (Session != null)
        {
            currentPhase = Session.Stage switch
            {
                "Generating" or "Refining" or "Refined" => "Writing",
                "Validating" => "Validating",
                "Evaluating" or "Evaluated" or "RefinementRequested" => "Evaluating", // Keep on Evaluating, but show as complete via IsEvaluatingCompleteWaitingForUser
                "GeneratingRubric" or "Rubric" => "Rubric",
                "Complete" => "Complete",
                "Failed" => "Failed",
                _ => currentPhase
            };
        }

        // Also update from latest phase event
        var latestPhase = Events.LastOrDefault(e => e.Type == AgentStreamEvent.EventType.PhaseStarted);
        if (latestPhase != null && !string.IsNullOrEmpty(latestPhase.Phase))
        {
            // Map event phases to our local phase names if they differ
            var mappedPhase = latestPhase.Phase switch
            {
                "Rubric" => "Rubric",
                "Writing" => "Writing",
                "Refining" => "Writing",
                "Validating" => "Validating",
                "Evaluating" => "Evaluating",
                "Complete" => "Complete",
                _ => latestPhase.Phase
            };

            if (phases.Contains(mappedPhase))
            {
                currentPhase = mappedPhase;
            }
        }
    }
}
