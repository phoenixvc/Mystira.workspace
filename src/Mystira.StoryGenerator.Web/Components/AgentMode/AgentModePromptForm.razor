@using Mystira.StoryGenerator.Contracts.Models

<div class="prompt-form">
    <h2>Create a Story with AI</h2>

    <div class="form-group">
        <label>Story Prompt</label>
        <textarea
            @bind="prompt"
            placeholder="Describe the story you want to create..."
            rows="5"
            disabled="@IsLoading" />
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Age Group</label>
            <select @bind="selectedAgeGroup" disabled="@IsLoading">
                <option value="1-2">Ages 1-2</option>
                <option value="3-5">Ages 3-5</option>
                <option value="6-9">Ages 6-9</option>
                <option value="10-12">Ages 10-12</option>
                <option value="13-18">Ages 13-18</option>
            </select>
        </div>

        <div class="form-group">
            <label>Knowledge Mode</label>
            <div class="radio-group">
                <label>
                    <input type="radio" name="knowledgeMode" value="FileSearch"
                           checked="@(knowledgeMode == "FileSearch")"
                           @onchange="@(() => knowledgeMode = "FileSearch")"
                           disabled="@IsLoading" />
                    File Search (Vector Store)
                </label>
                <label>
                    <input type="radio" name="knowledgeMode" value="AISearch"
                           checked="@(knowledgeMode == "AISearch")"
                           @onchange="@(() => knowledgeMode = "AISearch")"
                           disabled="@IsLoading" />
                    AI Search
                </label>
            </div>
        </div>
    </div>

    <button
        @onclick="Submit"
        disabled="@(IsLoading || string.IsNullOrWhiteSpace(prompt))"
        class="btn-primary">
        @if (IsLoading)
        {
            <span>⏳ Generating...</span>
        }
        else
        {
            <span>✨ Start Story</span>
        }
    </button>
</div>

@code {
    [Parameter] public EventCallback<StartSessionRequest> OnStartSession { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    private string prompt = "";
    private string selectedAgeGroup = "3-5";
    private string knowledgeMode = "FileSearch";

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(prompt))
            return;

        var request = new StartSessionRequest
        {
            StoryPrompt = prompt,
            AgeGroup = selectedAgeGroup,
            KnowledgeMode = knowledgeMode,
            TargetAxes = new List<string>() // Empty list - no axes selected
        };
        await OnStartSession.InvokeAsync(request);
    }
}
