@using Mystira.StoryGenerator.Api.Models
@using Mystira.StoryGenerator.Contracts.Models
@using System.Text.Json

<div class="refinement-panel">
    <h3>Refine Story</h3>

    <div class="refine-form">
        <div class="form-group">
            <label>
                <input type="checkbox" @bind="isFullRewrite" disabled="@IsLoading" />
                Full Rewrite (uncheck for targeted refinement)
            </label>
        </div>

        @if (!isFullRewrite)
        {
            <div class="form-group">
                <label>Target Scenes (select which scenes to refine)</label>
                <div class="checkbox-group">
                    @if (availableScenes.Any())
                    {
                        @foreach (var scene in availableScenes)
                        {
                            <label>
                                <input
                                    type="checkbox"
                                    @onchange="@((Microsoft.AspNetCore.Components.ChangeEventArgs e) => ToggleScene(scene, (bool)e.Value!))"
                                    disabled="@IsLoading" />
                                @scene.Title
                            </label>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No scenes available for selection</p>
                    }
                </div>
            </div>

            <div class="form-group">
                <label>Aspects to Focus On</label>
                <div class="checkbox-group">
                    @foreach (var aspect in availableAspects)
                    {
                        <label>
                            <input
                                type="checkbox"
                                @onchange="@((Microsoft.AspNetCore.Components.ChangeEventArgs e) => ToggleAspect(aspect, (bool)e.Value!))"
                                disabled="@IsLoading" />
                            @FormatAspectName(aspect)
                        </label>
                    }
                </div>
            </div>
        }

        <div class="form-group">
            <label>Additional Instructions</label>
            <textarea
                @bind="customInstructions"
                placeholder="e.g., Make the tone more humorous, Add more dialogue..."
                rows="3"
                disabled="@IsLoading" />
        </div>

        <button
            @onclick="Submit"
            disabled="@IsLoading"
            class="btn-primary">
            @if (IsLoading)
            {
                <span>🔄 Refining...</span>
            }
            else
            {
                <span>✨ Refine & Re-evaluate</span>
            }
        </button>
    </div>
</div>

@code {
    [Parameter] public SessionStateResponse? Session { get; set; }
    [Parameter] public EventCallback<RefineRequest> OnRefine { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    private bool isFullRewrite = true;
    private List<SceneInfo> availableScenes = new();
    private List<string> selectedScenes = new();
    private List<string> availableAspects = new()
    {
        "tone", "character_consistency", "pacing", "plot_logic", "dialogue", "descriptions"
    };
    private List<string> selectedAspects = new();
    private string customInstructions = "";

    protected override void OnParametersSet()
    {
        // Extract scenes from current story
        if (Session?.CurrentStoryJson != null && !string.IsNullOrWhiteSpace(Session.CurrentStoryJson))
        {
            try
            {
                var jsonDoc = JsonDocument.Parse(Session.CurrentStoryJson);
                availableScenes.Clear();

                if (jsonDoc.RootElement.TryGetProperty("scenes", out var scenesElement))
                {
                    int sceneIndex = 0;
                    foreach (var sceneElement in scenesElement.EnumerateArray())
                    {
                        var sceneId = sceneElement.TryGetProperty("scene_id", out var idProp)
                            ? idProp.GetString() ?? $"scene_{sceneIndex}"
                            : $"scene_{sceneIndex}";

                        var title = sceneElement.TryGetProperty("title", out var titleProp)
                            ? titleProp.GetString() ?? $"Scene {sceneIndex + 1}"
                            : $"Scene {sceneIndex + 1}";

                        availableScenes.Add(new SceneInfo
                        {
                            Id = sceneId,
                            Title = title
                        });
                        sceneIndex++;
                    }
                }
            }
            catch (JsonException ex)
            {
                Console.WriteLine($"Error parsing story JSON: {ex.Message}");
            }
        }
    }

    private void ToggleScene(SceneInfo scene, bool selected)
    {
        if (selected && !selectedScenes.Contains(scene.Id))
            selectedScenes.Add(scene.Id);
        else
            selectedScenes.Remove(scene.Id);
    }

    private void ToggleAspect(string aspect, bool selected)
    {
        if (selected && !selectedAspects.Contains(aspect))
            selectedAspects.Add(aspect);
        else
            selectedAspects.Remove(aspect);
    }

    private string FormatAspectName(string aspect)
    {
        return aspect.Replace("_", " ")
            .Split(' ')
            .Select(word => char.ToUpper(word[0]) + word.Substring(1))
            .Aggregate((a, b) => a + " " + b);
    }

    private async Task Submit()
    {
        var request = new RefineRequest
        {
            TargetSceneIds = isFullRewrite ? new() : selectedScenes,
            Aspects = selectedAspects,
            Constraints = customInstructions
        };
        await OnRefine.InvokeAsync(request);
    }

    private class SceneInfo
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
    }
}
