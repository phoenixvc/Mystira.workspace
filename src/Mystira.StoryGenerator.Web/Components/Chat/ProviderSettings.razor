@using Mystira.StoryGenerator.Web.Models
@inject IChatService ChatService
@inject IAiModelSettingsService ModelSettingsService
@inject ILogger<ProviderSettings> Logger

<div class="provider-settings">
    <div class="settings-header">
        <h4>AI Provider Settings</h4>
        <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshProviders">
            <span class="spinner-border spinner-border-sm @(isLoading ? "" : "d-none")" role="status"></span>
            @if (!isLoading)
            {
                <i class="refresh-icon">🔄</i>
            }
            Refresh
        </button>
    </div>

    <div class="form-group">
        <label for="provider-select">Provider:</label>
        <select id="provider-select" class="form-control" @bind="SelectedProvider">
            <option value="">-- Select Provider --</option>
            @foreach (var provider in availableProviders)
            {
                <option value="@provider.Name" disabled="@(!provider.Available)">
                    @provider.Name.ToUpperInvariant() @(provider.Available ? "" : " (Not Configured)")
                </option>
            }
        </select>
        @if (!string.IsNullOrEmpty(SelectedProvider) && !availableProviders.Any(p => p.Name == SelectedProvider && p.Available))
        {
            <small class="text-warning">⚠️ Selected provider is not available</small>
        }
    </div>

    <div class="form-group">
        <label for="model-select">Model:</label>
        <select id="model-select" class="form-control" @bind="SelectedModel" disabled="@string.IsNullOrEmpty(SelectedProvider)">
            <option value="">-- Select Model --</option>
            @foreach (var model in GetAvailableModelsForProvider(SelectedProvider))
            {
                <option value="@model.Id">@model.DisplayName</option>
            }
        </select>
        @if (!string.IsNullOrEmpty(SelectedModel))
        {
            var modelInfo = GetModelInfo(SelectedModel);
            if (modelInfo != null && !string.IsNullOrWhiteSpace(modelInfo.Description))
            {
                <small class="form-text text-muted">@modelInfo.Description</small>
            }
        }
    </div>

    <div class="form-group">
        <label for="model-id-input">Model Id:</label>
        <input id="model-id-input" type="text" class="form-control" @bind="ModelId"
               placeholder="Configured model id (e.g., story-gpt4o)" />
        <small class="form-text text-muted">
            Use when referencing a model configured on the server (Ai:Models).
        </small>
    </div>

    <div class="form-group">
        <label for="model-input">Model:</label>
        <input id="model-input" type="text" class="form-control" @bind="Model"
               placeholder="Leave empty to use default" />
        <small class="form-text text-muted">
            Examples: gpt-4o, gpt-4o-mini, gemini-pro
        </small>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label for="temperature-input">Temperature: <span class="temperature-value">@Temperature.ToString("F1")</span></label>
                <input id="temperature-input" type="range" class="form-range" min="0" max="2" step="0.1"
                       @bind="Temperature" />
                <div class="range-labels">
                    <small>Focused (0.0)</small>
                    <small>Creative (2.0)</small>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label for="max-tokens-input">Max Tokens:</label>
                <input id="max-tokens-input" type="number" class="form-control" min="1" max="4096"
                       @bind="MaxTokens" />
                <small class="form-text text-muted">1 - 4096</small>
            </div>
        </div>
    </div>



    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="ClearError"></button>
        </div>
    }

    <div class="provider-status">
        <strong>Available Providers: @availableProviders.Count(p => p.Available) / @availableProviders.Count</strong>
        <div class="provider-list">
            @foreach (var provider in availableProviders)
            {
                <div class="provider-item">
                    <span class="provider-status-indicator @(provider.Available ? "available" : "unavailable")">
                        @(provider.Available ? "✅" : "❌")
                    </span>
                    <span class="provider-name">@provider.Name.ToUpperInvariant()</span>
                </div>
            }
        </div>
    </div>
</div>

@code {
     [Parameter] public EventCallback<ProviderConfiguration> OnSettingsChanged { get; set; }
     [Parameter] public AiModelDefinition? CurrentModel { get; set; }
     [Parameter] public int CurrentMaxTokens { get; set; } = 1000;
     [Parameter] public double CurrentTemperature { get; set; } = 0.7;

     private List<ProviderInfo> availableProviders = new();
     private List<ProviderModels> availableProviderModels = new();
     private bool isLoading = true;
     private string errorMessage = string.Empty;

     private string _selectedProvider = string.Empty;
     private string SelectedProvider
     {
         get => _selectedProvider;
         set
         {
             var changed = _selectedProvider != value;
             _selectedProvider = value;
             if (changed)
             {
                 // Clear selected model when provider changes
                 _selectedModel = string.Empty;
             }
             NotifySettingsChanged();
         }
     }

     private string _selectedModel = string.Empty;
     private string SelectedModel
     {
         get => _selectedModel;
         set
         {
             _selectedModel = value;
             // Auto-populate the Model field when a model is selected
             if (!string.IsNullOrEmpty(value))
             {
                 var modelInfo = GetModelInfo(value);
                 if (modelInfo != null)
                 {
                     Model = modelInfo.Id;
                     Temperature = modelInfo.DefaultTemperature;
                     MaxTokens = modelInfo.MaxTokens;
                 }
             }
             NotifySettingsChanged();
         }
     }

     private string _modelId = string.Empty;
     private string ModelId
     {
         get => _modelId;
         set
         {
             _modelId = value;
             NotifySettingsChanged();
         }
     }

     private string _model = string.Empty;
     private string Model
     {
         get => _model;
         set
         {
             _model = value;
             NotifySettingsChanged();
         }
     }

     private double _temperature = 0.7;
     private double Temperature
     {
         get => _temperature;
         set
         {
             _temperature = value;
             NotifySettingsChanged();
         }
     }

     private int _maxTokens = 1000;
     private int MaxTokens
     {
         get => _maxTokens;
         set
         {
             _maxTokens = value;
             NotifySettingsChanged();
         }
     }

     private string _systemPrompt = string.Empty;
     private string SystemPrompt
     {
         get => _systemPrompt;
         set
         {
             _systemPrompt = value;
             NotifySettingsChanged();
         }
     }

     protected override async Task OnInitializedAsync()
     {
         await LoadProvidersAsync();
         await LoadModelsAsync();
     }

     protected override async Task OnParametersSetAsync()
     {
         // Initialize form with current model settings when parameters are passed
         if (CurrentModel != null)
         {
             _selectedModel = CurrentModel.Id;
             _model = CurrentModel.Deployment ?? CurrentModel.Id;
             _temperature = CurrentTemperature;
             _maxTokens = CurrentMaxTokens;
             _selectedProvider = CurrentModel.Provider ?? string.Empty;
             StateHasChanged();
         }
     }

    // No dynamic subscription needed; models are loaded on demand via ChatService

    private async Task LoadProvidersAsync()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            availableProviders = await ChatService.GetProvidersAsync();

            // Auto-select first available provider if none selected
            if (string.IsNullOrEmpty(SelectedProvider) && availableProviders.Any(p => p.Available))
            {
                SelectedProvider = availableProviders.First(p => p.Available).Name;
            }

            ClearError();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load providers");
            errorMessage = "Failed to load available providers. Please check your connection.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadModelsAsync()
    {
        try
        {
            var modelsResponse = await ChatService.GetModelsAsync();
            availableProviderModels = modelsResponse.Providers.ToList();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load models");
            errorMessage = "Failed to load available models. Please check your connection.";
        }
    }

    private async Task RefreshProviders()
    {
        await LoadProvidersAsync();
        await LoadModelsAsync();
    }

    private void OnProviderChanged()
    {
        // handled implicitly by SelectedProvider setter
    }

    private void OnModelChanged()
    {
        // handled implicitly by SelectedModel setter
    }

    private IEnumerable<ChatModelInfo> GetAvailableModelsForProvider(string providerName)
    {
        if (string.IsNullOrEmpty(providerName))
        {
            return Enumerable.Empty<ChatModelInfo>();
        }

        var providerModels = availableProviderModels.FirstOrDefault(p => p.Provider.Equals(providerName, StringComparison.OrdinalIgnoreCase));
        return providerModels?.Models ?? Enumerable.Empty<ChatModelInfo>();
    }

    private ChatModelInfo? GetModelInfo(string modelId)
    {
        if (string.IsNullOrEmpty(modelId))
        {
            return null;
        }

        return availableProviderModels
            .SelectMany(p => p.Models)
            .FirstOrDefault(m => m.Id.Equals(modelId, StringComparison.OrdinalIgnoreCase));
    }

    private async Task NotifySettingsChanged()
    {
        if (OnSettingsChanged.HasDelegate)
        {
            var settings = new ProviderConfiguration
            {
                Provider = SelectedProvider,
                ModelId = ModelId,
                Model = Model,
                Temperature = Temperature,
                MaxTokens = MaxTokens,
                SystemPrompt = SystemPrompt
            };

            await OnSettingsChanged.InvokeAsync(settings);
        }
    }

    private void ClearError()
    {
        errorMessage = string.Empty;
    }
}

<style>
    .provider-settings {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .settings-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .settings-header h4 {
        margin: 0;
        font-size: 1.1rem;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        font-weight: 600;
        margin-bottom: 0.25rem;
        display: block;
    }

    .temperature-value {
        color: #007bff;
        font-weight: bold;
    }

    .range-labels {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: #6c757d;
        margin-top: 0.25rem;
    }

    .provider-status {
        margin-top: 1rem;
        padding: 0.75rem;
        background: #ffffff;
        border-radius: 6px;
        border: 1px solid #e9ecef;
    }

    .provider-list {
        margin-top: 0.5rem;
    }

    .provider-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0.25rem 0;
    }

    .provider-status-indicator.available {
        color: #28a745;
    }

    .provider-status-indicator.unavailable {
        color: #dc3545;
    }

    .provider-name {
        font-weight: 500;
    }

    .refresh-icon {
        animation: spin 2s infinite linear;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .btn:hover .refresh-icon {
        animation-duration: 0.5s;
    }
</style>

@code {
    public class ProviderConfiguration
    {
        public string Provider { get; set; } = string.Empty;
        public string ModelId { get; set; } = string.Empty;
        public string Model { get; set; } = string.Empty;
        public double Temperature { get; set; } = 0.7;
        public int MaxTokens { get; set; } = 1000;
        public string SystemPrompt { get; set; } = string.Empty;
    }
}
