    }

    private async Task HandleDeleteChat(string chatId)
    {
        var chat = ChatHistories.FirstOrDefault(c => c.Id == chatId);
        if (chat != null)
        {
            ChatHistories.Remove(chat);
            pendingProposalsByChatId.Remove(chatId);
            if (CurrentChat?.Id == chatId)
            {
                CurrentChat = ChatHistories.FirstOrDefault();
                YamlContent = CurrentChat?.YamlSnapshot;
                ValidationResult = null;
            }
            await SaveChatsAsync();
            StateHasChanged();
        }
    }

    private async Task HandleNewChat()
    {
       CurrentChat = new StoryGeneratorChatHistory
       {
           Id = Guid.NewGuid().ToString(),
           Title = "New Story",
           CreatedAt = DateTime.Now,
           Messages = new List<StoryGeneratorChatMessage>()
       };

       // Add a welcome system message
       CurrentChat.Messages.Add(new StoryGeneratorChatMessage
       {
           Role = "system",
           Content = "Welcome to Mystira Story Generator! Describe your idea and I'll gather the required parameters.",
           Timestamp = DateTime.Now
       });

       currentViewedVersion = 1;
       ChatHistories.Insert(0, CurrentChat);
       await SaveChatsAsync();
       CloseMobileMenu();
       StateHasChanged();

        // Optionally kick off the setup flow with an initial prompt
        IsTyping = true;
        StateHasChanged();
        try
        {
            var settings = await GetSettingsAsync();
            var temperature = ClampTemperatureForCurrentModel(settings.Temperature);
            var maxTokens = ClampTokensForCurrentModel(settings.MaxTokens);

            var req = new ChatCompletionRequest
            {
                Provider = settings.Provider,
                ModelId = settings.ModelId,
                Model = settings.Deployment,
                Temperature = temperature,
                MaxTokens = maxTokens,
                Messages = new List<MystiraChatMessage>
                {
                    new MystiraChatMessage { MessageType = ChatMessageType.User, Content = "I'd like to generate a new story. Please start gathering the required parameters." }
                }
            };

            var resp = await ApiService.SetupStoryAsync(req);
            if (resp.Success && !string.IsNullOrWhiteSpace(resp.Content))
            {
                CurrentChat.Messages.Add(new StoryGeneratorChatMessage
                {
                    Role = "assistant",
                    Content = resp.Content,
                    Timestamp = DateTime.Now
                });
            }
            else if (!string.IsNullOrWhiteSpace(resp.Error))
            {
                CurrentChat.Messages.Add(new StoryGeneratorChatMessage
                {
                    Role = "assistant",
                    Content = $"Error starting setup: {resp.Error}",
                    Timestamp = DateTime.Now
                });
            }
            await SaveChatsAsync();
        }
        catch (Exception ex)
        {
            CurrentChat.Messages.Add(new StoryGeneratorChatMessage
            {
                Role = "assistant",
                Content = $"Failed to start setup: {ex.Message}",
                Timestamp = DateTime.Now
            });
            await SaveChatsAsync();
        }
        finally
        {
            IsTyping = false;
            StateHasChanged();
        }
    }

    private async Task HandleRandomizeStory(string difficultyKey)
    {
        if (!difficultyLookup.TryGetValue(difficultyKey, out var difficulty))
        {
            return;
        }

        IsTyping = true;
        StateHasChanged();

        StoryGeneratorChatHistory? chat = null;

        try
        {
            chat = await CreateFreshChatForDifficultyAsync(difficulty);
            StateHasChanged();

            var settings = await GetSettingsAsync();

            var request = new RandomStoryParametersRequest
            {
                Provider = settings.Provider,
                ModelId = settings.ModelId,
                Model = settings.Deployment,
                Difficulty = difficulty.DifficultyDisplay,
                SessionLength = difficulty.SessionLengthLabel,
                MinScenes = difficulty.MinScenes,
                MaxScenes = difficulty.MaxScenes
            };

            var response = await ApiService.RandomizeStoryParametersAsync(request);
            if (response.Success)
            {
                var difficultyLabel = string.IsNullOrWhiteSpace(response.Difficulty)
                    ? difficulty.DifficultyDisplay
                    : response.Difficulty;

                var sessionLabel = string.IsNullOrWhiteSpace(response.SessionLength)
                    ? difficulty.SessionLengthLabel
                    : response.SessionLength;

                var summary = BuildRandomProposalSummary(response, difficultyLabel, sessionLabel, difficulty);

                chat!.Messages.Add(new StoryGeneratorChatMessage
                {
                    Role = "assistant",
                    Content = summary,
                    Timestamp = DateTime.Now
                });

                var pending = new GenerateJsonStoryRequest
                {
                    Provider = !string.IsNullOrWhiteSpace(response.Provider) ? response.Provider : settings.Provider,
                    ModelId = !string.IsNullOrWhiteSpace(response.ModelId) ? response.ModelId : settings.ModelId,
                    Model = !string.IsNullOrWhiteSpace(response.Model) ? response.Model : settings.Deployment,
                    Title = !string.IsNullOrWhiteSpace(response.Title) ? response.Title : chat.Title,
                    Difficulty = difficultyLabel,
                    SessionLength = sessionLabel,
                    AgeGroup = response.AgeGroup,
                    MinimumAge = response.MinimumAge,
                    CoreAxes = response.CoreAxes ?? new List<string>(),
                    Archetypes = response.Archetypes ?? new List<string>(),
                    Tags = response.Tags,
                    Tone = response.Tone,
                    MinScenes = response.MinScenes > 0 ? response.MinScenes : difficulty.MinScenes,
                    MaxScenes = response.MaxScenes > 0 ? response.MaxScenes : difficulty.MaxScenes,
                    CharacterCount = response.CharacterCount
                };

                pendingProposalsByChatId[chat.Id] = pending;

                if (!string.IsNullOrWhiteSpace(response.Title))
                {
                    chat.Title = response.Title;
                }

                await SaveChatsAsync();
            }
            else
            {
                var errorMessage = response.Error ?? "Randomization failed";
                chat!.Messages.Add(new StoryGeneratorChatMessage
                {
                    Role = "assistant",
                    Content = $"Unable to generate random story parameters: {errorMessage}",
                    Timestamp = DateTime.Now
                });
                await SaveChatsAsync();
            }
        }
        catch (Exception ex)
        {
            var targetChat = chat ?? CurrentChat;
            if (targetChat != null)
            {
                targetChat.Messages.Add(new StoryGeneratorChatMessage
                {
                    Role = "assistant",
                    Content = $"Randomization error: {ex.Message}",
                    Timestamp = DateTime.Now
                });
                await SaveChatsAsync();
            }
        }
        finally
        {
            IsTyping = false;
            StateHasChanged();
        }
    }

    private async Task<StoryGeneratorChatHistory> CreateFreshChatForDifficultyAsync(DifficultyOption difficulty)
    {
        var timestamp = DateTime.Now;

        var chat = new StoryGeneratorChatHistory
        {
            Id = Guid.NewGuid().ToString(),
            Title = BuildDefaultRandomChatTitle(difficulty, timestamp),
            CreatedAt = timestamp,
            Messages = new List<StoryGeneratorChatMessage>()
        };

        chat.Messages.Add(new StoryGeneratorChatMessage
        {
            Role = "assistant",
            Content = BuildDifficultyIntroMessage(difficulty),
            Timestamp = timestamp
        });

        ChatHistories.Insert(0, chat);
        CurrentChat = chat;
        YamlContent = null;
        ValidationResult = null;
        pendingProposalsByChatId.Remove(chat.Id);

        await SaveChatsAsync();

        return chat;
    }

    private static string BuildDefaultRandomChatTitle(DifficultyOption difficulty, DateTime timestamp)
    {
        return $"{difficulty.TitlePrefix} ({timestamp:MMM d})";
    }

    private static string BuildDifficultyIntroMessage(DifficultyOption difficulty)
    {
        return $"🎯 {difficulty.DifficultyDisplay} adventure selected!\n\nI'm assembling a {difficulty.SessionLengthLabel} ({difficulty.SessionLengthDetails}) with {difficulty.MinScenes}-{difficulty.MaxScenes} scenes. Gathering inspiration now...";
    }

    private string BuildRandomProposalSummary(RandomStoryParametersResponse response, string difficultyLabel, string sessionLabel, DifficultyOption difficulty)
    {
        var title = !string.IsNullOrWhiteSpace(response.Title) ? response.Title : $"{difficulty.TitlePrefix} Adventure";
        var sessionDetails = string.IsNullOrWhiteSpace(difficulty.SessionLengthDetails)
            ? sessionLabel
            : $"{sessionLabel} ({difficulty.SessionLengthDetails})";
        var minScenes = response.MinScenes > 0 ? response.MinScenes : difficulty.MinScenes;
        var maxScenes = response.MaxScenes > 0 ? response.MaxScenes : difficulty.MaxScenes;
        var ageSummary = !string.IsNullOrWhiteSpace(response.AgeGroup)
            ? $"{response.AgeGroup} (min age {response.MinimumAge})"
            : (response.MinimumAge > 0 ? $"Minimum age {response.MinimumAge}+" : "All ages");
        var coreAxes = response.CoreAxes != null && response.CoreAxes.Any()
            ? string.Join(", ", response.CoreAxes)
            : "Curated during generation";
        var archetypes = response.Archetypes != null && response.Archetypes.Any()
            ? string.Join(", ", response.Archetypes)
            : "AI selected";
        var tags = response.Tags != null && response.Tags.Any()
            ? string.Join(", ", response.Tags)
            : "Surprise me";
        var tone = !string.IsNullOrWhiteSpace(response.Tone) ? response.Tone : "To be discovered";
        var characterSummary = response.CharacterCount > 0
            ? response.CharacterCount.ToString()
            : "Auto-determined";
        var description = !string.IsNullOrWhiteSpace(response.Description)
            ? response.Description
            : "I'll craft a fresh synopsis tailored to these parameters.";

        return $"🎲 {difficultyLabel} Random Adventure Proposal\n\n" +
               $"• Title: {title}\n" +
               $"• Difficulty: {difficultyLabel}\n" +
               $"• Session Length: {sessionDetails}\n" +
               $"• Age Group: {ageSummary}\n" +
               $"• Core Axes: {coreAxes}\n" +
               $"• Archetypes: {archetypes}\n" +
               $"• Character Count: {characterSummary}\n" +
               $"• Scenes: {minScenes}-{maxScenes}\n" +
               $"• Tags: {tags}\n" +
               $"• Tone: {tone}\n\n" +
               $"Description: {description}\n\n" +
               "Reply 'yes' to confirm and generate the story with these parameters.";
    }

    private async Task HandleSendMessage(string message)
    {
        if (CurrentChat == null)
        {
            await HandleNewChat();
        }

        // Add user message
        CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
        {
            Role = "user",
            Content = message,
            Timestamp = DateTime.Now
        });
        await SaveChatsAsync();

        // Set typing indicator
        IsTyping = true;
        StateHasChanged();

        // If a randomized proposal is pending, handle user confirmation without calling the LLM
        if (CurrentChat != null && pendingProposalsByChatId.TryGetValue(CurrentChat.Id, out var pending) && IsProceedMessage(message))
        {
            var chatId = CurrentChat.Id;
            try
            {
                CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
                {
                    Role = "system",
                    Content = "Generating story from the proposed parameters...",
                    Timestamp = DateTime.Now
                });
                StateHasChanged();

                var settings = await GetSettingsAsync();
                pending.Provider = settings.Provider;
                if (string.IsNullOrWhiteSpace(pending.ModelId))
                {
                    pending.ModelId = settings.ModelId;
                }
                if (string.IsNullOrWhiteSpace(pending.Model))
                {
                    pending.Model = settings.Deployment;
                }

                var result = await ApiService.GenerateJsonStoryAsync(pending);
                if (result.Success && !string.IsNullOrWhiteSpace(result.Json))
                {
                    var generatedYaml = JsonYamlConverter.ToYaml(result.Json);
                    YamlContent = generatedYaml;
                    CurrentChat!.YamlSnapshot = generatedYaml;
                    
                    // Create initial snapshot if this is the first generation
                    if (CurrentChat.YamlSnapshots.Count == 0)
                    {
                        CurrentChat.YamlSnapshots.Add(new YamlSnapshot
                        {
                            Version = 1,
                            Content = generatedYaml,
                            CreatedAt = DateTime.UtcNow
                        });
                    }
                    else
                    {
                        // Or create a new version if updating
                        var nextVersion = CurrentChat.YamlSnapshots.Max(s => s.Version) + 1;
                        CurrentChat.YamlSnapshots.Add(new YamlSnapshot
                        {
                            Version = nextVersion,
                            Content = generatedYaml,
                            CreatedAt = DateTime.UtcNow
                        });
                    }
                    
                    await SaveChatsAsync();

                    var validation = await ApiService.ValidateStoryAsync(generatedYaml, "yaml");
                    ValidationResult = MapValidation(validation);

                    var summary = BuildYamlSummaryMessage(generatedYaml);
                    CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
                    {
                        Role = "system",
                        Content = validation.IsValid
                            ? $"Story generated successfully. {summary}"
                            : $"Story generated but has issues. {BuildValidationSummary(validation)}",
                        Timestamp = DateTime.Now
                    });
                    await SaveChatsAsync();
                }
                else
                {
                    var emsg = result.Error ?? "Story generation failed";
                    CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
                    {
                        Role = "assistant",
                        Content = $"Story generation failed: {emsg}",
                        Timestamp = DateTime.Now
                    });
                    await SaveChatsAsync();
                }
            }
            finally
            {
                pendingProposalsByChatId.Remove(chatId);
                IsTyping = false;
                StateHasChanged();
            }
            return;
        }

        try
        {
            // Build chat completion request using conversation history
            var messages = MapToContractMessages(CurrentChat);
            if (ShouldIncludeYamlContext(message) && !string.IsNullOrWhiteSpace(YamlContent))
            {
                var currentJson = JsonYamlConverter.ToJson(YamlContent);
                messages.Add(new MystiraChatMessage
                {
                    MessageType = ChatMessageType.System,
                    Content = $"CURRENT_JSON:\n```json\n{currentJson}\n```",
                    Timestamp = DateTime.UtcNow
                });
            }

            var settings = await GetSettingsAsync();
            var temperature = ClampTemperatureForCurrentModel(settings.Temperature);
            var maxTokens = ClampTokensForCurrentModel(settings.MaxTokens);

            var request = new ChatCompletionRequest
            {
                Provider = settings.Provider,
                ModelId = settings.ModelId,
                Model = settings.Deployment,
                Temperature = temperature,
                MaxTokens = maxTokens,
                Messages = messages,
                CurrentStory = BuildStorySnapshot()
            };

            // Route subsequent turns to chat orchestration endpoint (not setup)
            var response = await ApiService.CompleteChatAsync(request);

            if (response.Success && !string.IsNullOrWhiteSpace(response.Content))
            {
                var content = response.Content;

                // If the assistant returned a JSON block representing a story, convert to YAML and apply without displaying JSON in chat
                if (TryExtractJsonCodeBlock(content, out var updatedJson))
                {
                    var convertedYaml = JsonYamlConverter.ToYaml(updatedJson);
                    if (!string.IsNullOrWhiteSpace(convertedYaml))
                    {
                        YamlContent = convertedYaml;
                        if (CurrentChat != null)
                        {
                            CurrentChat.YamlSnapshot = convertedYaml;
                            
                            // Create a new version snapshot when YAML is updated
                            var nextVersion = CurrentChat.YamlSnapshots.Count == 0 
                                ? 1 
                                : CurrentChat.YamlSnapshots.Max(s => s.Version) + 1;
                            CurrentChat.YamlSnapshots.Add(new YamlSnapshot
                            {
                                Version = nextVersion,
                                Content = convertedYaml,
                                CreatedAt = DateTime.UtcNow
                            });
                            
                            await SaveChatsAsync();
                        }

                        // Validate updated YAML
                        var validation = await ApiService.ValidateStoryAsync(convertedYaml, "yaml");
                        ValidationResult = MapValidation(validation);

                        // Add concise system message summarizing the update
                        CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
                        {
                            Role = "system",
                            Content = validation.IsValid
                                ? $"Story updated from JSON and validated successfully. {BuildYamlSummaryMessage(convertedYaml)}"
                                : $"Story updated from JSON but validation failed. Issues: {BuildValidationSummary(validation)}",
                            Timestamp = DateTime.Now
                        });
                        await SaveChatsAsync();
                        // Do not show the original assistant content (which contained JSON) in chat
                    }
                }
                // If YAML already exists and the assistant returned an updated YAML block, apply it without displaying in chat
                else if (!string.IsNullOrWhiteSpace(YamlContent) && TryExtractYamlCodeBlock(content, out var updatedYaml))
                {
                    YamlContent = updatedYaml;
                    if (CurrentChat != null)
                    {
                        CurrentChat.YamlSnapshot = updatedYaml;
                        await SaveChatsAsync();
                    }

                    // Validate updated YAML
                    var validation = await ApiService.ValidateStoryAsync(updatedYaml, "yaml");
                    ValidationResult = MapValidation(validation);

                    // Add concise system message
                    CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
                    {
                        Role = "system",
                        Content = validation.IsValid
                            ? $"Story updated and validated successfully. {BuildYamlSummaryMessage(updatedYaml)}"
                            : $"Story updated but validation failed. Issues: {BuildValidationSummary(validation)}",
                        Timestamp = DateTime.Now
                    });
                    await SaveChatsAsync();
                }
                else
                {
                    // Strip any JSON code blocks from assistant content before displaying (chat should never contain JSON)
                    var sanitized = RemoveJsonCodeBlocks(content);
                    // Add assistant response normally
                    CurrentChat.Messages.Add(new StoryGeneratorChatMessage
                    {
                        Role = "assistant",
                        Content = sanitized,
                        Timestamp = DateTime.Now
                    });
                    await SaveChatsAsync();
                }

                // Update title if it's a new chat
                if (CurrentChat.Title == "New Story")
                {
                    CurrentChat.Title = message.Length > 30 ? message[..30] + "..." : message;
                    await SaveChatsAsync();
                }

                // If parameters are complete, generate YAML and validate
                var generated = await TryGenerateYamlFromParamsAsync(content);
                if (generated)
                {
                    // Validate YAML content via API
                    if (!string.IsNullOrWhiteSpace(YamlContent))
                    {
                        ValidationResult = null;
                        StateHasChanged();

                        var validation = await ApiService.ValidateStoryAsync(YamlContent, "yaml");
                        ValidationResult = MapValidation(validation);

                        if (!validation.IsValid)
                        {
                            // Inform user and retry generation with validation feedback
                            CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
                            {
                                Role = "system",
                                Content = $"Generated story did not pass validation. Retrying with fixes. Issues: {BuildValidationSummary(validation)}",
                                Timestamp = DateTime.Now
                            });
                            await SaveChatsAsync();

                            var fixedYaml = await RetryFixYamlAsync(YamlContent, validation);
                            if (!string.IsNullOrWhiteSpace(fixedYaml))
                            {
                                YamlContent = fixedYaml;
                                CurrentChat.YamlSnapshot = fixedYaml;
                                
                                // Create a new version snapshot when YAML is fixed
                                var nextVersion = CurrentChat.YamlSnapshots.Count == 0 
                                    ? 1 
                                    : CurrentChat.YamlSnapshots.Max(s => s.Version) + 1;
                                CurrentChat.YamlSnapshots.Add(new YamlSnapshot
                                {
                                    Version = nextVersion,
                                    Content = fixedYaml,
                                    CreatedAt = DateTime.UtcNow
                                });
                                
                                await SaveChatsAsync();

                                var revalidation = await ApiService.ValidateStoryAsync(fixedYaml, "yaml");
                                ValidationResult = MapValidation(revalidation);

                                // Add a concise system message instead of dumping YAML in chat
                                var summary = BuildYamlSummaryMessage(fixedYaml);
                                CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
                                {
                                    Role = "system",
                                    Content = revalidation.IsValid
                                        ? $"Story regenerated and validated successfully. {summary}"
                                        : $"Story regenerated but still has issues. {BuildValidationSummary(revalidation)}",
                                    Timestamp = DateTime.Now
                                });
                                await SaveChatsAsync();
                            }
                        }
                    }
                }
            }
            else
            {
                var err = response.Error ?? "Failed to get response from AI";
                CurrentChat.Messages.Add(new StoryGeneratorChatMessage
                {
                    Role = "assistant",
                    Content = $"Error: {err}",
                    Timestamp = DateTime.Now
                });
                await SaveChatsAsync();
            }
        }
        catch (Exception ex)
        {
            CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
            {
                Role = "assistant",
                Content = $"An error occurred: {ex.Message}",
                Timestamp = DateTime.Now
            });
            await SaveChatsAsync();
        }
        finally
        {
            IsTyping = false;
            StateHasChanged();
        }
    }

