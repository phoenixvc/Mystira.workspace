@using System.Linq
@using Mystira.StoryGenerator.Contracts.Stories
@using Mystira.StoryGenerator.Web.Models
@inherits LayoutComponentBase
@implements IDisposable
@inject IStoryApiService ApiService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IJSRuntime JSRuntime
@inject IAiModelSettingsService ModelSettingsService
@inject IYamlImportService YamlImportService
@inject ILogger<ThreePanelLayout> Logger

<div class="h-screen bg-gray-100 flex flex-col">
    <!-- Header -->
    <header class="bg-white border-b border-gray-200 px-6 py-4 flex-shrink-0">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-4">
                <button type="button"
                        class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-200 text-gray-600 transition-colors hover:border-primary-300 hover:text-primary-600"
                        @onclick="ToggleSidebarAsync"
                        aria-label="Toggle sidebar">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
                <h1 class="text-2xl font-bold text-gray-900">Mystira Story Generator</h1>
                <span class="bg-primary-100 text-primary-800 text-xs font-medium px-2.5 py-0.5 rounded-full">
                    Beta
                </span>
            </div>
            <div class="flex items-center space-x-4">
                <button class="text-gray-500 hover:text-gray-700 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                </button>
                <button class="text-gray-500 hover:text-gray-700 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </button>
                <button type="button"
                        class="inline-flex items-center gap-2 rounded-lg border border-gray-200 px-3 py-1.5 text-sm font-medium text-gray-600 transition-colors hover:border-primary-300 hover:text-primary-600"
                        @onclick="OpenSettingsModal">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-1.14 1.95-1.14 2.25 0a1.125 1.125 0 001.76.62c.96-.64 2.2.6 1.56 1.56a1.125 1.125 0 00.62 1.76c1.14.3 1.14 1.95 0 2.25a1.125 1.125 0 00-.62 1.76c.64.96-.6 2.2-1.56 1.56a1.125 1.125 0 00-1.76.62c-.3 1.14-1.95 1.14-2.25 0a1.125 1.125 0 00-1.76-.62c-.96.64-2.2-.6-1.56-1.56a1.125 1.125 0 00-.62-1.76c-1.14-.3-1.14-1.95 0-2.25a1.125 1.125 0 00.62-1.76c-.64-.96.6-2.2 1.56-1.56.68.45 1.58.08 1.76-.62z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <span class="hidden sm:inline">AI Settings</span>
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-1 flex overflow-hidden relative">
        <!-- Syncfusion Sidebar - Left Panel -->
        <SfSidebar @ref="sidebarRef"
                   Width="320px"
                   Type="SidebarType.Push"
                   Position="SidebarPosition.Left"
                   DockSize="80px"
                   EnableDock="false"
                   ShowBackdrop="false"
                   MediaQuery="(min-width: 1024px)"
                   Target=".sidebar-main-content"
                   @bind-IsOpen="sidebarIsOpen">
            <ChildContent>
                <div class="flex flex-col h-full bg-gray-50 border-r border-gray-200">
                    <div class="p-3 bg-white border-b">
                         <div class="flex flex-col gap-3">
                             <div class="flex items-center justify-between gap-2">
                                 <span class="text-xs font-semibold uppercase tracking-wide text-gray-500">Random Adventures</span>
                                 <div class="relative">
                                     <button type="button"
                                             class="text-gray-500 hover:text-gray-700 p-1 rounded hover:bg-gray-100 transition-colors"
                                             @onclick="ToggleImportMenu"
                                             title="Import YAML story">
                                         <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                         </svg>
                                     </button>
                                     @if (showImportMenu)
                                     {
                                         <div class="absolute top-8 right-0 bg-white border border-gray-200 rounded-md shadow-lg z-10 min-w-[160px]">
                                             <button type="button"
                                                     class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 flex items-center gap-2"
                                                     @onclick="ImportFromClipboard">
                                                 <span>📋</span>
                                                 <span>From Clipboard</span>
                                             </button>
                                             <button type="button"
                                                     class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 flex items-center gap-2 border-t border-gray-200"
                                                     @onclick="TriggerFileInput">
                                                 <span>📁</span>
                                                 <span>From File</span>
                                             </button>
                                         </div>
                                     }
                                 </div>
                             </div>
                             <div class="flex flex-col gap-2">
                                 @foreach (var option in difficultyOptions)
                                 {
                                     <button type="button"
                                             class="@($"difficulty-button difficulty-{option.Key}")"
                                             @onclick="async () => await HandleRandomizeStory(option.Key)">
                                         <span class="difficulty-icon">
                                             @((MarkupString)option.IconSvg)
                                         </span>
                                         <span class="difficulty-text">
                                             <span class="difficulty-label">@option.ButtonHeading</span>
                                             <span class="difficulty-meta">@option.ButtonDescription</span>
                                         </span>
                                         <span class="difficulty-pill">@option.DifficultyDisplay</span>
                                     </button>
                                 }
                             </div>
                         </div>
                         <div class="mt-2">
                             <input class="w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
                                    placeholder="Fuzzy search chats..."
                                    @bind="searchQuery"
                                    @bind:event="oninput" />
                         </div>
                     </div>

                    <InputFile OnChange="HandleFileSelect" hidden accept=".yaml,.yml" />
                    <div class="flex-1 overflow-hidden">
                        <ChatHistoryPanel ChatHistories="@GetFilteredChatHistories()"
                                        OnChatSelected="@HandleChatSelected"
                                        OnNewChatClicked="@HandleNewChat"
                                        OnDeleteChat="@HandleDeleteChat"
                                        SearchQuery="@searchQuery" />
                    </div>
                </div>
            </ChildContent>
        </SfSidebar>

        <!-- Center & Right Panels (50%/50%) -->
        <div class="sidebar-main-content flex flex-1 overflow-hidden">
            <!-- Center Panel - Active Chat (50%) -->
            <div id="panel-center" class="panel bg-white">
                <ActiveChatPanel CurrentChat="@CurrentChat"
                               IsTyping="@IsTyping"
                               OnSendMessage="@HandleSendMessage"
                               OnClearChat="@HandleClearChat" />
            </div>

            <!-- Right Panel - YAML Preview (50%) -->
            <div id="panel-right" class="panel border-l border-gray-200 bg-gray-50" style="width:@($"{rightWidth}%")">
               <YamlPreviewPanel YamlContent="@YamlContent"
                               ValidationResult="@ValidationResult"
                               OnYamlCopied="@HandleYamlCopied"
                               OnYamlSaved="@HandleYamlSaved"
                               OnValidateRequested="@HandleValidateYaml"
                               SyntaxColors="@yamlPreviewTheme"
                               YamlSnapshots="@(CurrentChat?.YamlSnapshots ?? new())"
                               CurrentVersion="@GetCurrentVersion()"
                               OnVersionSelected="@HandleVersionSelected" />
            </div>
        </div>

        <style>
            .panel {
                height: 100%;
                overflow: hidden;
                flex: 1 1 50%;
                min-width: 0;
            }
            .difficulty-button {
                display: flex;
                align-items: center;
                width: 100%;
                gap: 0.75rem;
                padding: 0.85rem 0.95rem;
                border-radius: 0.75rem;
                border: 1px solid transparent;
                color: #ffffff;
                font-weight: 600;
                cursor: pointer;
                transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
            }
            .difficulty-button:hover {
                transform: translateY(-1px);
                box-shadow: 0 12px 22px rgba(15, 23, 42, 0.18);
                filter: brightness(1.03);
            }
            .difficulty-button:focus {
                outline: none;
                box-shadow: 0 0 0 0.2rem rgba(59, 130, 246, 0.35);
            }
            .difficulty-button .difficulty-icon {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 2.75rem;
                height: 2.75rem;
                border-radius: 9999px;
                background-color: rgba(255, 255, 255, 0.18);
            }
            .difficulty-button .difficulty-icon svg {
                width: 1.5rem;
                height: 1.5rem;
            }
            .difficulty-button .difficulty-text {
                display: flex;
                flex-direction: column;
                align-items: flex-start;
                gap: 0.2rem;
            }
            .difficulty-button .difficulty-label {
                font-size: 0.95rem;
                line-height: 1.2;
            }
            .difficulty-button .difficulty-meta {
                font-size: 0.75rem;
                font-weight: 500;
                opacity: 0.9;
            }
            .difficulty-button .difficulty-pill {
                margin-left: auto;
                padding: 0.3rem 0.65rem;
                border-radius: 9999px;
                font-size: 0.7rem;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                font-weight: 700;
                border: 1px solid rgba(255, 255, 255, 0.35);
                background-color: rgba(255, 255, 255, 0.18);
            }
            .difficulty-button.difficulty-easy {
                background-image: linear-gradient(135deg, #34d399, #059669);
                border-color: rgba(16, 185, 129, 0.9);
            }
            .difficulty-button.difficulty-easy .difficulty-icon {
                background-color: rgba(16, 185, 129, 0.35);
            }
            .difficulty-button.difficulty-easy .difficulty-pill {
                background-color: rgba(6, 95, 70, 0.45);
                border-color: rgba(167, 243, 208, 0.4);
            }
            .difficulty-button.difficulty-medium {
                background-image: linear-gradient(135deg, #60a5fa, #2563eb);
                border-color: rgba(37, 99, 235, 0.9);
            }
            .difficulty-button.difficulty-medium .difficulty-icon {
                background-color: rgba(37, 99, 235, 0.35);
            }
            .difficulty-button.difficulty-medium .difficulty-pill {
                background-color: rgba(30, 64, 175, 0.45);
                border-color: rgba(191, 219, 254, 0.45);
            }
            .difficulty-button.difficulty-hard {
                background-image: linear-gradient(135deg, #f97316, #ea580c);
                border-color: rgba(234, 88, 12, 0.85);
            }
            .difficulty-button.difficulty-hard .difficulty-icon {
                background-color: rgba(234, 88, 12, 0.35);
            }
            .difficulty-button.difficulty-hard .difficulty-pill {
                background-color: rgba(154, 52, 18, 0.45);
                border-color: rgba(254, 215, 170, 0.45);
            }
        </style>
    </main>

    @if (!string.IsNullOrWhiteSpace(copyFeedbackMessage))
    {
        <div class="fixed bottom-6 right-6 z-50">
            <div class="@GetCopyToastClasses()">
                @if (copyFeedbackSuccess)
                {
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                }
                else
                {
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                }
                <span>@copyFeedbackMessage</span>
            </div>
        </div>
    }

    @if (showSettingsModal)
    {

        <div class="absolute inset-0 bg-black bg-opacity-50" @onclick="CloseSettingsModal"></div>

        <div class="relative z-50 w-full max-w-xl px-4" @onclick:stopPropagation>
            <div class="mx-auto overflow-hidden rounded-xl bg-white shadow-2xl">
                <div class="flex items-center justify-between border-b border-gray-200 px-6 py-4">
                    <h2 class="text-lg font-semibold text-gray-900">AI Model Settings</h2>
                    <button type="button" class="text-gray-400 transition-colors hover:text-gray-600" @onclick="CloseSettingsModal">
                        <span class="sr-only">Close</span>
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
                <div class="space-y-5 px-6 py-5">
                    <div class="space-y-2">
                        <label class="text-sm font-medium text-gray-700" for="model-select">Model</label>
                        <select id="model-select"
                                class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
                                value="@selectedModelId"
                                @onchange="HandleModelChanged">
                            @if (availableModels.Any())
                            {
                                foreach (var model in availableModels)
                                {
                                    <option value="@model.Id">@model.DisplayName (@model.Provider)</option>
                                }
                            }
                            else
                            {
                                <option value="" disabled>Loading models…</option>
                            }
                        </select>
                        @if (!string.IsNullOrWhiteSpace(selectedModelDefinition?.Description))
                        {
                            <p class="text-sm text-gray-500">@selectedModelDefinition!.Description</p>
                        }
                    </div>
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-gray-700" for="tokens-input">Max Tokens</label>
                            <input id="tokens-input"
                                   type="number"
                                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
                                   min="@GetMinTokens()"
                                   max="@GetMaxTokens()"
                                   @bind-value="selectedMaxTokens"
                                   @bind-value:event="oninput" />
                            <p class="text-xs text-gray-500">Allowed: @GetMinTokens() - @GetMaxTokens()</p>
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-gray-700" for="temperature-input">Temperature</label>
                            <input id="temperature-input"
                                   type="number"
                                   step="0.05"
                                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
                                   min="@GetMinTemperature()"
                                   max="@GetMaxTemperature()"
                                   @bind-value="selectedTemperature"
                                   @bind-value:event="oninput" />
                            <p class="text-xs text-gray-500">Allowed: @GetMinTemperature().ToString("0.00") - @GetMaxTemperature().ToString("0.00")</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(settingsError))
                    {
                        <div class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
                            @settingsError
                        </div>
                    }
                </div>
                <div class="flex items-center justify-end gap-3 border-t border-gray-200 bg-gray-50 px-6 py-4">
                    <button type="button" class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100" @onclick="CloseSettingsModal">Cancel</button>
                    <button type="button"
                            class="inline-flex items-center gap-2 rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary-700 disabled:cursor-not-allowed disabled:opacity-60"
                            @onclick="SaveSettingsAsync"
                            disabled="@isSavingSettings">
                        @if (isSavingSettings)
                        {
                            <svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                            </svg>
                        }
                        <span>Save</span>
                    </button>
                </div>
            </div>
        </div>
    }

    @if (showImportResult)
    {
        <div class="absolute inset-0 bg-black bg-opacity-50" @onclick="CloseImportResult"></div>

        <div class="relative z-50 w-full max-w-xl px-4" @onclick:stopPropagation>
            <div class="mx-auto overflow-hidden rounded-xl bg-white shadow-2xl">
                <div class="flex items-center justify-between border-b border-gray-200 px-6 py-4">
                    <h2 class="text-lg font-semibold text-gray-900">
                        @(importResult?.IsValid == true ? "✅ Story Imported" : "❌ Import Failed")
                    </h2>
                    <button type="button" class="text-gray-400 transition-colors hover:text-gray-600" @onclick="CloseImportResult">
                        <span class="sr-only">Close</span>
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
                <div class="space-y-5 px-6 py-5">
                    @if (importResult?.IsValid == true)
                    {
                        <div class="whitespace-pre-wrap text-sm text-gray-700 leading-relaxed">
                            @((MarkupString)(importResult.Summary ?? ""))
                        </div>
                    }
                    else
                    {
                        <div class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
                            @importResult?.ErrorMessage
                        </div>
                    }
                </div>
                <div class="flex items-center justify-end gap-3 border-t border-gray-200 bg-gray-50 px-6 py-4">
                    <button type="button" class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100" @onclick="CloseImportResult">Close</button>
                    @if (importResult?.IsValid == true)
                    {
                        <button type="button"
                                class="inline-flex items-center gap-2 rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary-700"
                                @onclick="ConfirmImport">
                            <span>Continue to Chat</span>
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private record DifficultyOption(
        string Key,
        string DifficultyDisplay,
        string ButtonHeading,
        string ButtonDescription,
        string SessionLengthLabel,
        string SessionLengthDetails,
        int MinScenes,
        int MaxScenes,
        string TitlePrefix,
        string IconSvg);

    private readonly List<DifficultyOption> difficultyOptions = new()
    {
        new DifficultyOption(
            Key: "easy",
            DifficultyDisplay: "Easy",
            ButtonHeading: "Easy Quest",
            ButtonDescription: "Quick warm-up • 8-12 scenes",
            SessionLengthLabel: "Quick Quest",
            SessionLengthDetails: "~5 mins",
            MinScenes: 8,
            MaxScenes: 121,
            TitlePrefix: "Easy Quest",
            IconSvg: """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21M4.75 12H3m18 0h-1.75M5.636 5.636 4.5 4.5m14.864 14.864 1.136 1.136M18.364 5.636 19.5 4.5M5.636 18.364 4.5 19.5M8.25 12a3.75 3.75 0 016.75-2m-6.75 0a3.75 3.75 0 006.75 2m-6.75 0H7.5m6.75 0h1.5" /></svg>""")
        ,
        new DifficultyOption(
            Key: "medium",
            DifficultyDisplay: "Medium",
            ButtonHeading: "Heroic Journey",
            ButtonDescription: "Balanced challenge • 20-40 scenes",
            SessionLengthLabel: "Standard Session",
            SessionLengthDetails: "~15 mins",
            MinScenes: 20,
            MaxScenes: 40,
            TitlePrefix: "Heroic Journey",
            IconSvg: """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 5.25l-9-3-9 3v6.75a12 12 0 009 11.25 12 12 0 009-11.25V5.25z" /></svg>""")
        ,
        new DifficultyOption(
            Key: "hard",
            DifficultyDisplay: "Hard",
            ButtonHeading: "Epic Saga",
            ButtonDescription: "Deep narrative • 80-120 scenes",
            SessionLengthLabel: "Extended Session",
            SessionLengthDetails: "30+ mins",
            MinScenes: 80,
            MaxScenes: 120,
            TitlePrefix: "Epic Saga",
            IconSvg: """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 9.75a3.75 3.75 0 11-6 3 3.75 3.75 0 00-5.25 3.5A7.5 7.5 0 1018 12.75c0 .94-.18 1.84-.5 2.67" /></svg>""")
    };

    private readonly Dictionary<string, DifficultyOption> difficultyLookup;
    // Tracks the most recent randomized proposal per chat so users can confirm later
    private readonly Dictionary<string, GenerateJsonStoryRequest> pendingProposalsByChatId = new();

    public ThreePanelLayout()
    {
        difficultyLookup = difficultyOptions.ToDictionary(option => option.Key, StringComparer.OrdinalIgnoreCase);
    }

    // Sidebar state
    private SfSidebar? sidebarRef;
    private bool sidebarIsOpen = false;
    private bool showSettingsModal;

    // Data properties
    private List<StoryGeneratorChatHistory> ChatHistories = new();
    private StoryGeneratorChatHistory? CurrentChat;
    private bool IsTyping = false;
    private string? YamlContent;
    private YamlValidationResult? ValidationResult;
    private int currentViewedVersion = 1;

    // UI state
    private string searchQuery = string.Empty;
    private string? copyFeedbackMessage;
    private bool copyFeedbackSuccess;
    private CancellationTokenSource? copyFeedbackCts;
    private readonly TimeSpan copyFeedbackDuration = TimeSpan.FromSeconds(4);

    // Import state
    private bool showImportMenu = false;
    private bool showImportResult = false;
    private YamlImportResult? importResult;

    private const string ChatsStorageKey = "mystira_story_generator_chats";

    private readonly YamlSyntaxColorScheme yamlPreviewTheme = YamlSyntaxColorScheme.Default with
    {
