    private IEnumerable<StoryGeneratorChatHistory> GetFilteredChatHistories()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return ChatHistories;
        var q = searchQuery.Trim();
        return ChatHistories.Where(c => MatchesChat(c, q)).ToList();
    }

    private bool MatchesChat(StoryGeneratorChatHistory chat, string query)
    {
        if (FuzzyMatch(chat.Title, query)) return true;
        // Search last few messages for fuzzy match
        foreach (var m in chat.Messages.AsEnumerable().Reverse().Take(5))
        {
            if (FuzzyMatch(m.Content, query)) return true;
        }
        return false;
    }

    private static bool IsProceedMessage(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return false;
        var t = input.Trim().ToLowerInvariant();
        return t == "yes" || t == "y" || t.Contains("proceed") || t.Contains("generate") || t.Contains("go ahead") || t.Contains("continue");
    }

    private static readonly char[] SearchSeparators = " \t\r\n,.;:-_/\\|()[]{}\"'!?@#$%^&*+=".ToCharArray();

    private bool FuzzyMatch(string? source, string query)
    {
        if (string.IsNullOrWhiteSpace(source) || string.IsNullOrWhiteSpace(query))
        {
            return false;
        }

        var normalizedSource = source.ToLowerInvariant();
        var terms = query.ToLowerInvariant().Split(SearchSeparators, StringSplitOptions.RemoveEmptyEntries);
        if (terms.Length == 0)
        {
            return false;
        }

        var tokens = normalizedSource.Split(SearchSeparators, StringSplitOptions.RemoveEmptyEntries);
        if (tokens.Length == 0)
        {
            tokens = new[] { normalizedSource };
        }

        foreach (var term in terms)
        {
            if (normalizedSource.Contains(term))
            {
                continue;
            }

            var matched = false;
            foreach (var token in tokens)
            {
                if (token.Contains(term) || Similarity(token, term) >= 0.72)
                {
                    matched = true;
                    break;
                }
            }

            if (!matched)
            {
                return false;
            }
        }

        return true;
    }

    private static int LevenshteinDistance(string s, string t)
    {
        if (string.IsNullOrEmpty(s)) return t.Length;
        if (string.IsNullOrEmpty(t)) return s.Length;
        var d = new int[s.Length + 1, t.Length + 1];
        for (int i = 0; i <= s.Length; i++) d[i, 0] = i;
        for (int j = 0; j <= t.Length; j++) d[0, j] = j;
        for (int i = 1; i <= s.Length; i++)
        {
            for (int j = 1; j <= t.Length; j++)
            {
                var cost = char.ToLowerInvariant(s[i - 1]) == char.ToLowerInvariant(t[j - 1]) ? 0 : 1;
                d[i, j] = Math.Min(
                    Math.Min(d[i - 1, j] + 1, d[i, j - 1] + 1),
                    d[i - 1, j - 1] + cost);
            }
        }
        return d[s.Length, t.Length];
    }

    private static double Similarity(string a, string b)
    {
        var maxLen = Math.Max(a.Length, b.Length);
        if (maxLen == 0) return 1.0;
        var dist = LevenshteinDistance(a, b);
        return 1.0 - (double)dist / maxLen;
    }

    private bool ShouldIncludeYamlContext(string input)
    {
        if (string.IsNullOrWhiteSpace(input) || string.IsNullOrWhiteSpace(YamlContent)) return false;
        var text = input.ToLowerInvariant();
        var keywords = new[] { "yaml", "scene", "scenes", "choice", "choices", "roll", "narrative", "branch", "branches", "path", "paths", "edit", "update", "change", "modify" };
        return keywords.Any(k => text.Contains(k));
    }

    private string BuildYamlSummaryMessage(string yaml)
    {
        var (totalScenes, totalPaths, choiceScenes, rollScenes, narrativeScenes) = SummarizeYaml(yaml);
        return $"Summary: {totalScenes} scenes • {totalPaths} possible paths • {choiceScenes} choice scenes • {rollScenes} roll scenes • {narrativeScenes} narrative scenes.\nIf you'd like any changes, describe what to modify (for example: 'Make scene 2 a roll scene with DC 12', 'Add a new branch from scene_2', or 'Rename scene_3').";
    }

    private (int totalScenes, int totalPaths, int choiceScenes, int rollScenes, int narrativeScenes) SummarizeYaml(string yaml)
    {
        int totalScenes = 0, choiceScenes = 0, rollScenes = 0, narrativeScenes = 0, totalPaths = 0;
        bool inScenes = false;
        bool inChoices = false;
        bool inBranches = false;

        foreach (var rawLine in yaml.Split('\n'))
        {
            var line = rawLine.Trim();
            if (string.IsNullOrWhiteSpace(line) || line.StartsWith("#")) continue;

            if (line.StartsWith("scenes:"))
            {
                inScenes = true;
                inChoices = false;
                inBranches = false;
                continue;
            }

            if (inScenes && line.StartsWith("- id:"))
            {
                totalScenes++;
                inChoices = false;
                inBranches = false;
                continue;
            }

            if (inScenes && line.StartsWith("type:"))
            {
                var typeVal = line.Substring("type:".Length).Trim().Trim('"');
                var t = typeVal.ToLowerInvariant();
                if (t.Contains("choice") || t.Contains("decision") || t.Contains("branch")) choiceScenes++;
                else if (t.Contains("roll") || t.Contains("skill")) rollScenes++;
                else if (t.Contains("narrative") || t.Contains("story")) narrativeScenes++;
                continue;
            }

            if (inScenes && (line.StartsWith("choices:") || line.StartsWith("branches:")))
            {
                inChoices = line.StartsWith("choices:");
                inBranches = line.StartsWith("branches:");
                continue;
            }

            if ((inChoices || inBranches) && line.StartsWith("- "))
            {
                totalPaths++;
            }
        }

        // Fallback: if no explicit choices counted, try to detect transitions in story_flow
        if (totalPaths == 0)
        {
            foreach (var rawLine in yaml.Split('\n'))
            {
                var line = rawLine.Trim();
                if (line.StartsWith("- from:") || line.StartsWith("- to:"))
                {
                    if (line.StartsWith("- from:")) totalPaths++;
                }
            }
        }

        return (totalScenes, totalPaths, choiceScenes, rollScenes, narrativeScenes);
    }

