    private static readonly EffectiveAiModelSettings FallbackModelSettings = AiModelDefaults.CreateEffectiveSettings();
    private bool modelSettingsInitialized;
    private List<AiModelDefinition> availableModels = new() { FallbackModelSettings.Definition };
    private EffectiveAiModelSettings currentModelSettings = FallbackModelSettings;
    private AiModelDefinition? selectedModelDefinition = FallbackModelSettings.Definition;
    private string selectedModelId = FallbackModelSettings.ModelId;
    private int selectedMaxTokens = FallbackModelSettings.MaxTokens;
    private double selectedTemperature = FallbackModelSettings.Temperature;
    private bool isSavingSettings;
    private string? settingsError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var saved = await LocalStorage.GetItemAsync<List<StoryGeneratorChatHistory>>(ChatsStorageKey);
            ChatHistories = saved ?? new List<StoryGeneratorChatHistory>();
            CurrentChat = ChatHistories.FirstOrDefault();
            YamlContent = CurrentChat?.YamlSnapshot;
            currentViewedVersion = CurrentChat?.YamlSnapshots.Count > 0
               ? CurrentChat.YamlSnapshots.Max(s => s.Version)
               : 1;
        }
        catch
        {
            ChatHistories = new List<StoryGeneratorChatHistory>();
        }

        await EnsureModelSettingsAsync();

        await base.OnInitializedAsync();
    }

    private async Task ToggleSidebarAsync()
    {
        sidebarIsOpen = !sidebarIsOpen;
        await InvokeAsync(StateHasChanged);
    }

    private async Task EnsureModelSettingsAsync()
    {
        if (modelSettingsInitialized)
        {
            return;
        }

        try
        {
            await ModelSettingsService.InitializeAsync();
            var models = await ModelSettingsService.GetAvailableModelsAsync();
            availableModels = models.OrderBy(m => m.DisplayName).ToList();

            await RefreshModelSettingsAsync();

            ModelSettingsService.SettingsChanged += HandleModelSettingsChanged;
        }
        catch
        {
            availableModels = new List<AiModelDefinition> { currentModelSettings.Definition };
        }
        finally
        {
            modelSettingsInitialized = true;
        }
    }

    private async Task RefreshModelSettingsAsync(bool reloadOptions = false)
    {
        if (reloadOptions)
        {
            var models = await ModelSettingsService.GetAvailableModelsAsync();
            availableModels = models.OrderBy(m => m.DisplayName).ToList();
        }

        currentModelSettings = await ModelSettingsService.GetEffectiveSettingsAsync();
        selectedModelDefinition = currentModelSettings.Definition;
        selectedModelId = currentModelSettings.ModelId;
        selectedMaxTokens = currentModelSettings.MaxTokens;
        selectedTemperature = Math.Round(currentModelSettings.Temperature, 2);
    }

    private async Task<EffectiveAiModelSettings> GetSettingsAsync()
    {
        await EnsureModelSettingsAsync();
        return currentModelSettings;
    }

    private async Task OpenSettingsModal()
    {
        await EnsureModelSettingsAsync();
        settingsError = null;
        isSavingSettings = false;
        selectedModelDefinition = currentModelSettings.Definition;
        selectedModelId = currentModelSettings.ModelId;
        selectedMaxTokens = currentModelSettings.MaxTokens;
        selectedTemperature = Math.Round(currentModelSettings.Temperature, 2);
        showSettingsModal = true;
    }

    private void CloseSettingsModal()
    {
        showSettingsModal = false;
        settingsError = null;
        isSavingSettings = false;
    }

    private void HandleModelChanged(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        var modelId = e.Value?.ToString() ?? string.Empty;
        var definition = availableModels.FirstOrDefault(m => string.Equals(m.Id, modelId, StringComparison.OrdinalIgnoreCase))
                         ?? availableModels.FirstOrDefault()
                         ?? currentModelSettings.Definition;

        selectedModelId = definition.Id;
        selectedModelDefinition = definition;
        selectedMaxTokens = definition.DefaultMaxTokens;
        selectedTemperature = Math.Round(definition.DefaultTemperature, 2);
        settingsError = null;
    }

    private async Task SaveSettingsAsync()
    {
        if (selectedModelDefinition == null)
        {
            settingsError = "Select a model before saving.";
            return;
        }

        var minTokens = GetMinTokens();
        var maxTokens = GetMaxTokens();
        var desiredTokens = selectedMaxTokens <= 0 ? selectedModelDefinition.DefaultMaxTokens : selectedMaxTokens;

        if (desiredTokens < minTokens || desiredTokens > maxTokens)
        {
            settingsError = $"Max tokens must be between {minTokens} and {maxTokens}.";
            return;
        }

        var minTemp = GetMinTemperature();
        var maxTemp = GetMaxTemperature();
        var desiredTemperature = double.IsNaN(selectedTemperature) ? selectedModelDefinition.DefaultTemperature : selectedTemperature;

        if (desiredTemperature < minTemp || desiredTemperature > maxTemp)
        {
            settingsError = $"Temperature must be between {minTemp:0.00} and {maxTemp:0.00}.";
            return;
        }

        isSavingSettings = true;
        try
        {
            await ModelSettingsService.UpdateSelectionAsync(selectedModelDefinition.Id, desiredTokens, desiredTemperature);
            await RefreshModelSettingsAsync();
            showSettingsModal = false;
            settingsError = null;
        }
        finally
        {
            isSavingSettings = false;
        }
    }

    private int GetMinTokens()
    {
        var definition = selectedModelDefinition ?? currentModelSettings.Definition;
        return definition.MinTokens.HasValue && definition.MinTokens.Value > 0 ? definition.MinTokens.Value : 1;
    }

    private int GetMaxTokens()
    {
        var definition = selectedModelDefinition ?? currentModelSettings.Definition;
        if (definition.MaxTokensLimit.HasValue && definition.MaxTokensLimit.Value > 0)
        {
            return definition.MaxTokensLimit.Value;
        }

        return Math.Max(definition.DefaultMaxTokens, GetMinTokens());
    }

    private double GetMinTemperature()
    {
        var definition = selectedModelDefinition ?? currentModelSettings.Definition;
        return definition.MinTemperature ?? 0.0;
    }

    private double GetMaxTemperature()
    {
        var definition = selectedModelDefinition ?? currentModelSettings.Definition;
        return definition.MaxTemperature ?? 2.0;
    }

    private int ClampTokensForCurrentModel(int value)
    {
        var definition = currentModelSettings.Definition;
        var min = definition.MinTokens.HasValue && definition.MinTokens.Value > 0 ? definition.MinTokens.Value : 1;
        var max = definition.MaxTokensLimit.HasValue && definition.MaxTokensLimit.Value > 0
            ? Math.Max(definition.MaxTokensLimit.Value, min)
            : Math.Max(definition.DefaultMaxTokens, min);

        if (value <= 0)
        {
            value = definition.DefaultMaxTokens;
        }

        return Math.Clamp(value, min, max);
    }

    private double ClampTemperatureForCurrentModel(double value)
    {
        var definition = currentModelSettings.Definition;
        var min = definition.MinTemperature ?? 0.0;
        var max = definition.MaxTemperature ?? 2.0;
        if (double.IsNaN(value) || double.IsInfinity(value))
        {
            value = definition.DefaultTemperature;
        }
        return Math.Clamp(value, min, max);
    }

    private async void HandleModelSettingsChanged(object? sender, System.EventArgs e)
    {
        await InvokeAsync(async () =>
        {
            await RefreshModelSettingsAsync();
            StateHasChanged();
        });
    }

    private async Task HandleChatSelected(StoryGeneratorChatHistory chat)
    {
       CurrentChat = chat;
       YamlContent = CurrentChat?.YamlSnapshot;
       currentViewedVersion = CurrentChat?.YamlSnapshots.Count > 0
           ? CurrentChat.YamlSnapshots.Max(s => s.Version)
           : 1;
       CloseMobileMenu();
