    private async Task HandleYamlCopied(YamlCopyResult result)
    {
        copyFeedbackCts?.Cancel();
        copyFeedbackCts?.Dispose();
        var currentCts = new CancellationTokenSource();
        copyFeedbackCts = currentCts;

        copyFeedbackMessage = result.Message;
        copyFeedbackSuccess = result.Success;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(copyFeedbackDuration, currentCts.Token);
            if (!currentCts.IsCancellationRequested && copyFeedbackCts == currentCts)
            {
                copyFeedbackMessage = null;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
            // Swallow cancellation when a new notification arrives or the component disposes
        }
    }

