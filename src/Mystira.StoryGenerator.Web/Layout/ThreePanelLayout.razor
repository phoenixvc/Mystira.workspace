    private List<MystiraChatMessage> MapToContractMessages(StoryGeneratorChatHistory chat)
    {
        var list = new List<MystiraChatMessage>();
        foreach (var m in chat.Messages)
        {
            var type = m.Role?.ToLower() switch
            {
                "user" => ChatMessageType.User,
                "assistant" => ChatMessageType.AI,
                "system" => ChatMessageType.System,
                _ => ChatMessageType.User
            };

            list.Add(new MystiraChatMessage
            {
                MessageType = type,
                Content = m.Content,
                Timestamp = m.Timestamp
            });
        }
        return list;
    }

    private async Task<bool> TryGenerateYamlFromParamsAsync(string aiContent)
    {
        try
        {
            const string marker = "PARAMS_JSON:";
            var idx = aiContent.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
            if (idx < 0)
            {
                return false;
            }

            var json = aiContent.Substring(idx + marker.Length).Trim();
            json = StripCodeFences(json);

            var options = new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            };

            var payload = System.Text.Json.JsonSerializer.Deserialize<ParameterPayload>(json, options);
            if (payload == null)
            {
                return false;
            }

            if (string.IsNullOrWhiteSpace(payload.title) ||
                string.IsNullOrWhiteSpace(payload.difficulty) ||
                string.IsNullOrWhiteSpace(payload.session_length) ||
                string.IsNullOrWhiteSpace(payload.age_group) ||
                payload.minimum_age <= 0 ||
                payload.core_axes == null || payload.core_axes.Count == 0 ||
                payload.archetypes == null || payload.archetypes.Count == 0)
            {
                return false;
            }

            var minScenes = payload.min_scenes > 0 ? payload.min_scenes : 6;
            var maxScenes = payload.max_scenes >= minScenes ? payload.max_scenes : Math.Max(12, minScenes + 1);

            var settings = await GetSettingsAsync();

            var request = new GenerateJsonStoryRequest
            {
                Provider = settings.Provider,
                ModelId = settings.ModelId,
                Model = settings.Deployment,
                Title = payload.title,
                Difficulty = NormalizeDifficulty(payload.difficulty),
                SessionLength = NormalizeSessionLength(payload.session_length),
                AgeGroup = payload.age_group,
                MinimumAge = payload.minimum_age,
                CoreAxes = payload.core_axes,
                Archetypes = payload.archetypes,
                Tags = payload.tags ?? new List<string>(),
                Tone = payload.tone,
                MinScenes = minScenes,
                MaxScenes = maxScenes,
                CharacterCount = payload.character_count > 0 ? payload.character_count : (payload.archetypes?.Count ?? 0)
            };

            // Inform user we're generating YAML
            CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
            {
                Role = "system",
                Content = "All parameters received. Generating story...",
                Timestamp = DateTime.Now
            });
            StateHasChanged();

            var result = await ApiService.GenerateJsonStoryAsync(request);
            if (result.Success && !string.IsNullOrWhiteSpace(result.Json))
            {
                YamlContent = JsonYamlConverter.ToYaml(result.Json);
                if (CurrentChat != null)
                {
                    CurrentChat.YamlSnapshot = YamlContent;
                    
                    // Create initial snapshot if this is the first generation
                    if (CurrentChat.YamlSnapshots.Count == 0)
                    {
                        CurrentChat.YamlSnapshots.Add(new YamlSnapshot
                        {
                            Version = 1,
                            Content = YamlContent,
                            CreatedAt = DateTime.UtcNow
                        });
                    }
                    
                    var summary = BuildYamlSummaryMessage(YamlContent);
                    CurrentChat.Messages.Add(new StoryGeneratorChatMessage
                    {
                        Role = "system",
                        Content = summary,
                        Timestamp = DateTime.Now
                    });
                    await SaveChatsAsync();
                }
                return true;
            }
            else
            {
                var emsg = result.Error ?? "YAML generation failed";
                CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
                {
                    Role = "assistant",
                    Content = $"YAML generation failed: {emsg}",
                    Timestamp = DateTime.Now
                });
                await SaveChatsAsync();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            CurrentChat!.Messages.Add(new StoryGeneratorChatMessage
            {
                Role = "assistant",
                Content = $"Error during Story generation: {ex.Message}",
                Timestamp = DateTime.Now
            });
            await SaveChatsAsync();
        }

        return false;
    }

    private static string NormalizeDifficulty(string difficulty)
    {
        var d = (difficulty ?? string.Empty).Trim().ToLowerInvariant();
        return d switch
        {
            "easy" => "Easy",
            "medium" or "moderate" => "Medium",
            "hard" => "Hard",
            _ => "Medium"
        };
    }

    private static string NormalizeSessionLength(string length)
    {
        var l = (length ?? string.Empty).Trim().ToLowerInvariant();
        return l switch
        {
            "short" => "Short",
            "medium" or "moderate" => "Medium",
            "long" => "Long",
            _ => "Medium"
        };
    }

    private static string StripCodeFences(string input)
    {
        var s = input.Trim();
        if (s.StartsWith("```"))
        {
            s = s.TrimStart('`');
            var newlineIndex = s.IndexOf('\n');
            if (newlineIndex > -1)
            {
                s = s.Substring(newlineIndex + 1);
            }
        }
        if (s.EndsWith("```") && s.LastIndexOf("```", StringComparison.Ordinal) >= 0)
        {
            s = s.Substring(0, s.LastIndexOf("```", StringComparison.Ordinal));
        }
        return s.Trim();
    }

    private static YamlValidationResult MapValidation(ValidationResponse response)
    {
        var result = new YamlValidationResult
        {
            IsValid = response.IsValid,
            Errors = new List<string>()
        };

        foreach (var e in response.Errors)
        {
            result.Errors.Add($"Error at {e.Path}: {e.Message}");
        }
        foreach (var w in response.Warnings)
        {
            result.Errors.Add($"Warning at {w.Path}: {w.Message}");
        }
        foreach (var s in response.Suggestions)
        {
            result.Errors.Add($"Suggestion at {s.Path}: {s.Message}");
        }

        return result;
    }

    private static string BuildValidationSummary(ValidationResponse validation)
    {
        if (validation == null) return "(no details)";
        var parts = new List<string>();
        foreach (var e in validation.Errors.Take(5))
        {
            parts.Add($"{e.Path}: {e.Message}");
        }
        return parts.Count == 0 ? "No specific error details available" : string.Join("; ", parts);
    }

    private static bool TryExtractYamlCodeBlock(string content, out string yaml)
    {
        yaml = string.Empty;
        if (string.IsNullOrWhiteSpace(content)) return false;

        var start = content.IndexOf("```", StringComparison.Ordinal);
        if (start < 0) return false;

        var langEnd = content.IndexOf('\n', start + 3);
        if (langEnd < 0) return false;

        var fenceLabel = content.Substring(start + 3, langEnd - (start + 3)).Trim().ToLowerInvariant();
        var end = content.IndexOf("```", langEnd + 1, StringComparison.Ordinal);
        if (end < 0) return false;

        var code = content.Substring(langEnd + 1, end - (langEnd + 1));
        if (fenceLabel == "yaml" || fenceLabel == "yml" || fenceLabel == string.Empty)
        {
            yaml = code.Trim();
            return !string.IsNullOrWhiteSpace(yaml);
        }
        return false;
    }

    private async Task<string?> RetryFixYamlAsync(string currentYaml, ValidationResponse validation)
    {
        try
        {
            if (CurrentChat == null) return null;

            var messages = MapToContractMessages(CurrentChat);
            var currentJson = JsonYamlConverter.ToJson(currentYaml);
            messages.Add(new MystiraChatMessage
            {
                MessageType = ChatMessageType.System,
                Content = $"CURRENT_JSON:\n```json\n{currentJson}\n```",
                Timestamp = DateTime.UtcNow
            });

            var issueList = string.Join("\n", validation.Errors.Select(e => $"- {e.Path}: {e.Message}"));
            messages.Add(new MystiraChatMessage
            {
                MessageType = ChatMessageType.User,
                Content = $"Using the CURRENT_JSON context above, the story failed validation. Please regenerate a corrected JSON that fixes these issues while preserving IDs and structure where possible. Return only a JSON block. Issues:\n{issueList}",
                Timestamp = DateTime.UtcNow
            });

            var settings = await GetSettingsAsync();
            var fixTemperature = ClampTemperatureForCurrentModel(Math.Min(settings.Temperature, 0.6));
            var maxTokens = ClampTokensForCurrentModel(settings.MaxTokens);

            var request = new ChatCompletionRequest
            {
                Provider = settings.Provider,
                ModelId = settings.ModelId,
                Model = settings.Deployment,
                Temperature = fixTemperature,
                MaxTokens = maxTokens,
                Messages = messages
            };

            // Use chat orchestration for fix attempts; expect JSON block back which we then convert to YAML
            var resp = await ApiService.CompleteChatAsync(request);
            if (resp.Success && !string.IsNullOrWhiteSpace(resp.Content))
            {
                if (TryExtractJsonCodeBlock(resp.Content, out var fixedJson))
                {
                    var yaml = JsonYamlConverter.ToYaml(fixedJson);
                    return string.IsNullOrWhiteSpace(yaml) ? null : yaml;
                }
            }
        }
        catch
        {
            // Ignore and return null on failure
        }
        return null;
    }

    // Detect a fenced JSON code block and return its inner JSON
    private static bool TryExtractJsonCodeBlock(string content, out string json)
    {
        json = string.Empty;
        if (string.IsNullOrWhiteSpace(content)) return false;

        // Normalize and attempt to handle raw JSON payloads (no code fences)
        // Some providers return a plain JSON object/array as the entire message content.
        // Also strip any leading label like "CURRENT_JSON:" that may precede the payload.
        var trimmed = content.Trim();
        if (trimmed.StartsWith("CURRENT_JSON:", StringComparison.OrdinalIgnoreCase))
        {
            trimmed = trimmed.Substring("CURRENT_JSON:".Length).Trim();
        }

        // If the whole content appears to be JSON, validate and return it.
        if ((trimmed.StartsWith("{") && trimmed.EndsWith("}")) ||
            (trimmed.StartsWith("[") && trimmed.EndsWith("]")))
        {
            try
            {
                // Validate JSON; if it parses, accept it as-is
                using var _ = System.Text.Json.JsonDocument.Parse(trimmed);
                json = trimmed;
                return true;
            }
            catch
            {
                // Not valid raw JSON; fall through to fenced block detection
            }
        }

        var idx = 0;
        while (idx < content.Length)
        {
            var start = content.IndexOf("```", idx, StringComparison.Ordinal);
            if (start < 0) break;
            var langEnd = content.IndexOf('\n', start + 3);
            if (langEnd < 0) break;

            var fenceLabel = content.Substring(start + 3, langEnd - (start + 3)).Trim().ToLowerInvariant();
            var end = content.IndexOf("```", langEnd + 1, StringComparison.Ordinal);
            if (end < 0) break;

            var code = content.Substring(langEnd + 1, end - (langEnd + 1));
            // Accept explicit json labels (json/jsonc), or unlabeled blocks that parse as JSON
            var isJsonLabeled = fenceLabel == "json" || fenceLabel.StartsWith("json");
            if (isJsonLabeled)
            {
                var candidate = code.Trim();
                if (!string.IsNullOrWhiteSpace(candidate))
                {
                    json = candidate;
                    return true;
                }
            }
            else
            {
                // If no label, try to parse code as JSON to be tolerant of providers omitting the language tag
                var candidate = code.Trim();
                if (!string.IsNullOrWhiteSpace(candidate))
                {
                    try
                    {
                        using var _ = System.Text.Json.JsonDocument.Parse(candidate);
                        json = candidate;
                        return true;
                    }
                    catch
                    {
                        // Not JSON; continue scanning
                    }
                }
            }
            idx = end + 3;
        }
        return false;
    }

    // Remove any fenced JSON code blocks (and any leading CURRENT_JSON lines) from assistant content before displaying in chat
    private static string RemoveJsonCodeBlocks(string content)
    {
        if (string.IsNullOrEmpty(content)) return content;

        // Remove CURRENT_JSON label lines preceding code fences
        var sanitized = content.Replace("CURRENT_JSON:", string.Empty, StringComparison.OrdinalIgnoreCase);

        // Remove all ```json ... ``` blocks
        int startIdx;
        while ((startIdx = sanitized.IndexOf("```json", StringComparison.OrdinalIgnoreCase)) >= 0)
        {
            var endIdx = sanitized.IndexOf("```", startIdx + 7, StringComparison.Ordinal);
            if (endIdx < 0)
            {
                // No closing fence; remove from start to end
                sanitized = sanitized.Remove(startIdx);
                break;
            }
            var length = (endIdx + 3) - startIdx;
            sanitized = sanitized.Remove(startIdx, length);
        }

        // Trim excess whitespace left by removals
        return sanitized.Trim();
    }

    public void Dispose()
    {
        ModelSettingsService.SettingsChanged -= HandleModelSettingsChanged;
        if (copyFeedbackCts != null)
        {
            copyFeedbackCts.Cancel();
            copyFeedbackCts.Dispose();
            copyFeedbackCts = null;
        }
    }

    private void ToggleImportMenu()
    {
        showImportMenu = !showImportMenu;
        StateHasChanged();
    }

    private async Task ImportFromClipboard()
    {
        try
        {
            showImportMenu = false;
            var result = await JSRuntime.InvokeAsync<dynamic>("mystiraClipboard.readText");

            if (result != null && (bool)result["success"] == true)
            {
                var yamlContent = (string?)result["text"];
                if (yamlContent != null)
                {
                    importResult = await YamlImportService.ImportYamlAsync(yamlContent);
                }
                else
                {
                    importResult = new YamlImportResult
                    {
                        IsValid = false,
                        ErrorMessage = "Clipboard content is empty"
                    };
                }
            }
            else
            {
                importResult = new YamlImportResult
                {
                    IsValid = false,
                    ErrorMessage = "Unable to read clipboard. Please check permissions or try importing from file."
                };
            }

            showImportResult = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error importing from clipboard");
            importResult = new YamlImportResult
            {
                IsValid = false,
                ErrorMessage = $"Error reading clipboard: {ex.Message}"
            };
            showImportResult = true;
            StateHasChanged();
        }
    }

    private async Task TriggerFileInput()
    {
        showImportMenu = false;
        await JSRuntime.InvokeVoidAsync("eval", $"document.querySelector('input[type=\"file\"]').click()");
    }

    private async Task HandleFileSelect(InputFileChangeEventArgs e)
    {
        try
        {
            // Access the file through the event argument
            var file = e.File;

            // Read the file content
            using var streamReader = new StreamReader(file.OpenReadStream());
            string yamlContent = await streamReader.ReadToEndAsync();

            importResult = await YamlImportService.ImportYamlAsync(yamlContent);
            showImportResult = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error importing from file");
            importResult = new YamlImportResult
            {
                IsValid = false,
                ErrorMessage = $"Error reading file: {ex.Message}"
            };
            showImportResult = true;
            StateHasChanged();
        }
    }

    private async Task ConfirmImport()
    {
        if (importResult?.IsValid != true || string.IsNullOrEmpty(importResult.YamlContent))
            return;

        try
        {
            var newChat = new StoryGeneratorChatHistory
            {
                Id = Guid.NewGuid().ToString(),
                Title = "Imported Story",
                CreatedAt = DateTime.UtcNow,
                Messages = new List<StoryGeneratorChatMessage>()
            };

            var systemMessage = new StoryGeneratorChatMessage
            {
                Role = "system",
                Content = importResult.Summary ?? "Story imported successfully",
                Timestamp = DateTime.UtcNow
            };
            newChat.Messages.Add(systemMessage);

            ChatHistories.Insert(0, newChat);
            CurrentChat = newChat;
            YamlContent = importResult.YamlContent;
            currentViewedVersion = 1;

            // Create initial snapshot for imported story
            newChat.YamlSnapshots.Add(new YamlSnapshot
            {
                Version = 1,
                Content = importResult.YamlContent,
                CreatedAt = DateTime.UtcNow
            });
            newChat.YamlSnapshot = importResult.YamlContent;

            await SaveChatsAsync();

            CloseImportResult();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating session from import");
            importResult = new YamlImportResult
            {
                IsValid = false,
                ErrorMessage = $"Error creating session: {ex.Message}"
            };
            StateHasChanged();
        }
    }

    private void CloseImportResult()
    {
        showImportResult = false;
        importResult = null;
        StateHasChanged();
    }

    private StorySnapshot? BuildStorySnapshot()
    {
        if (CurrentChat == null || string.IsNullOrWhiteSpace(YamlContent))
        {
            return null;
        }

        return new StorySnapshot
        {
            StoryId = CurrentChat.Id,
            StoryVersion = 1,
            Content = JsonYamlConverter.ToJson(YamlContent)
        };
    }

