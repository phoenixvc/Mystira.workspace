     {
         public string title { get; set; } = string.Empty;
         public string? theme { get; set; }
         public string difficulty { get; set; } = string.Empty;
         public string session_length { get; set; } = string.Empty;
         public string age_group { get; set; } = string.Empty;
         public int minimum_age { get; set; }
         public List<string> core_axes { get; set; } = new();
         public List<string> archetypes { get; set; } = new();
         public int min_scenes { get; set; } = 6;
         public int max_scenes { get; set; } = 12;
         public List<string>? tags { get; set; }
         public string? tone { get; set; }
         public int character_count { get; set; } = 0;
     }
