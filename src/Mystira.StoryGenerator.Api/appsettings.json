{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ai": {
    "DefaultProvider": "azure-openai",
    "DefaultTemperature": 0.7,
    "DefaultMaxTokens": 4096,
    "AzureOpenAI": {
      "Endpoint": "https://dev-swe-ai-mystira-stor-resource.openai.azure.com/",
      "ApiKey": "YOUR_AZURE_OPENAI_API_KEY",
      "DeploymentName": "gpt-4.1",
      "EmbeddingDeploymentName": "text-embedding-3-large",
      "SchemaValidation" : {
        "SchemaPath" : "config/story-schema.json",
        "IsSchemaValidationStrict" : true,
        "//IsSchemaValidationStrict": "We had to remove allOf & if-then from schema to enable strict validation, which is desired, to be true. System prompt must ne updated to reflect these rules."
      }
    },
    "GoogleGemini": {
      "ApiKey": "YOUR_GOOGLE_API_KEY",
      "Model": "gemini-pro"
    }
  },
  "InstructionSearch": {
    "Endpoint": "https://your-search-resource.search.windows.net",
    "ApiKey": "YOUR_SEARCH_API_KEY",
    "IndexName": "mystira-instructions",
    "VectorFieldName": "contentVector",
    "IdFieldName": "id",
    "ContentFieldName": "chunk",
    "CategoryFieldName": "category",
    "InstructionTypeFieldName": "instruction_type",
    "MandatoryFieldName": "is_mandatory",
    "OrderFieldName": "order",
    "TagsFieldName": "tags",
    "DefaultTopK": 6,
    "MandatoryChunkLimit": 12
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5074",
      "https://localhost:5074",
      "https://dev-euw-app-mystira-story-generator-web-cxfkfcccfpd2a5hh.westeurope-01.azurewebsites.net"
    ]
  }
}
